# ═══════════════════════════════════════════════════════════════
# ARKIS AGENCY — Variables d'environnement
# Copier ce fichier en .env et remplir avec vos vraies valeurs
# NE JAMAIS COMMITTER .env dans le contrôle de version
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (Base de données PostgreSQL) ─────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Brevo (Emails transactionnels) ───────────────────────────
BREVO_API_KEY=your_brevo_api_key_here

# ─── Contact Email Configuration ──────────────────────────────
CONTACT_EMAIL_TO=contact@arkis.agency
CONTACT_EMAIL_FROM_ADDR=contact@arkis.agency
CONTACT_EMAIL_FROM_NAME=Arkis Agency

# ─── Cloudflare Turnstile (CAPTCHA) ──────────────────────────
TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ─── Serveur Express ──────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Domaines autorisés (CORS / CSRF) ────────────────────────
ALLOWED_ORIGINS=https://arkis.agency,https://www.arkis.agency
