        <li><a href="/live" class="nav-link <%= typeof page !== 'undefined' && page === 'live' ? 'active' : '' %>" style="display:inline-flex; align-items:center; gap:0.35rem; justify-content:center;">Live SOC <span style="width: 6px; height: 6px; background:var(--clr-green); border-radius:50%; display:inline-block; animation: pulseGlow 1.5s infinite;"></span></a></li>
