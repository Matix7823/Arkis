<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO -->
  <title><%= typeof title !== 'undefined' ? title : 'Arkis — Agence Web & Cybersécurité' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Arkis — Agence hybride : création de sites web sur-mesure + cybersécurité intégrée dès la conception (Secure by Design).' %>" />
  <meta name="keywords" content="agence web, cybersécurité, SOC, SIEM, pen-testing, développement web, Secure by Design" />
  <meta name="author" content="Arkis" />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Arkis" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Arkis — Agence Web & Cybersécurité' %>" />
  <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : 'Sites web sur-mesure + cybersécurité intégrée. Secure by Design.' %>" />

  <!-- PWA -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#4f46e5" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' fill='none'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='32' y2='32' gradientUnits='userSpaceOnUse'%3E%3Cstop offset='0%25' stop-color='%234f46e5'/%3E%3Cstop offset='100%25' stop-color='%2306b6d4'/%3E%3C/linearGradient%3E%3C/defs%3E%3Cpath d='M6 26 L16 4 L26 26 L21 26 L16 14 L11 26 Z' fill='url(%23g)'/%3E%3C/svg%3E" />

  <!-- Fonts (chargement avec crossorigin pour isolation) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" crossorigin="anonymous" referrerpolicy="no-referrer" />

  <!-- Styles -->
  <link rel="stylesheet" href="/style.css?v=<%= typeof buildVersion !== 'undefined' ? buildVersion : Date.now() %>" />

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Arkis",
    "description": "Agence web hybride : développement sur-mesure + cybersécurité.",
    "url": "https://arkis.agency",
    "areaServed": "France"
  }
  </script>
</head>
<body<%= typeof page !== 'undefined' && page === 'live' ? ' class="soc-page"' : '' %>>
