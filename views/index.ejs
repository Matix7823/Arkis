<%- include('partials/head', {
  title: 'Arkis — Agence Web & Cybersécurité',
  description: 'Sites web sur-mesure + cybersécurité intégrée dès la conception. Création, monitoring SOC/SIEM 24/7, audit de sécurité.'
}) %>

<%- include('partials/header') %>

<!-- ═══ HERO ═══ -->
<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content reveal">
      <span class="eyebrow"><span class="dot"></span> Agence hybride · Web + Sécurité</span>
      <h1>Le web <span class="gradient-text">propre</span>, sécurisé dès la première ligne de code.</h1>
      <p class="lead">
        Arkis conçoit des sites et applications web sur-mesure avec une cybersécurité intégrée dès la conception.
        Création, déploiement, monitoring SOC 24/7 — tout en un.
      </p>
      <div class="hero-ctas">
        <a href="/contact" class="btn btn-primary btn-lg">
          Démarrer un projet
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/live" class="btn btn-secondary btn-lg">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          Voir le Live SOC
        </a>
      </div>
      <div class="hero-trust">
        <div class="hero-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Audit gratuit 30 min
        </div>
        <div class="hero-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Réponse sous 24h
        </div>
        <div class="hero-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          100% basé en France
        </div>
      </div>
    </div>

    <!-- Hero visual : terminal + KPI cards -->
    <div class="hero-visual reveal">
      <div class="hv-card hv-terminal" aria-hidden="true">
        <div class="hv-term-bar">
          <div class="dots"><span></span><span></span><span></span></div>
          <div class="hv-term-title">arkis@soc — security-scan</div>
        </div>
        <div class="hv-term-body">
          <span class="ln"><span class="pr">$</span>arkis scan --target client.fr</span>
          <span class="ln"><span class="dim">→ Initializing scan...</span></span>
          <span class="ln"><span class="info">[INFO]</span> Probing 247 endpoints</span>
          <span class="ln"><span class="ok">[OK]</span> TLS 1.3 — A+ rating</span>
          <span class="ln"><span class="ok">[OK]</span> Headers: HSTS, CSP, X-Frame</span>
          <span class="ln"><span class="warn">[WARN]</span> 1 outdated dep · patched</span>
          <span class="ln"><span class="ok">[OK]</span> SQL injection: not vulnerable</span>
          <span class="ln"><span class="ok">[OK]</span> XSS: not vulnerable</span>
          <span class="ln"><span class="info">[INFO]</span> Score: <span class="ok">98 / 100</span></span>
          <span class="ln"><span class="pr">$</span><span class="hv-cursor"></span></span>
        </div>
      </div>
      <div class="hv-card hv-mini-card">
        <div class="label">Uptime · 30j</div>
        <div class="value">99.99<small>%</small></div>
        <svg class="hv-spark" viewBox="0 0 100 32" preserveAspectRatio="none">
          <polyline points="0,24 12,18 24,22 36,12 48,16 60,8 72,10 84,4 100,6" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="hv-card hv-mini-card">
        <div class="label">Attaques bloquées · 24h</div>
        <div class="value">12.8k<small>+18%</small></div>
        <svg class="hv-spark" viewBox="0 0 100 32" preserveAspectRatio="none">
          <polyline points="0,28 12,24 24,20 36,22 48,14 60,18 72,10 84,12 100,4" fill="none" stroke="#4f46e5" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- ═══ STATS ═══ -->
<section class="section section-sm">
  <div class="container">
    <div class="stats-row">
      <div class="stat">
        <div class="stat-value">99.99<span style="font-size:1.25rem;color:var(--text-3)">%</span></div>
        <div class="stat-label">Uptime moyen</div>
      </div>
      <div class="stat">
        <div class="stat-value">&lt; 1.2<span style="font-size:1.25rem;color:var(--text-3)">s</span></div>
        <div class="stat-label">Time to interactive</div>
      </div>
      <div class="stat">
        <div class="stat-value">A+</div>
        <div class="stat-label">Note SSL Labs</div>
      </div>
      <div class="stat">
        <div class="stat-value">24/7</div>
        <div class="stat-label">Monitoring SOC</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ SERVICES ═══ -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Nos services</span>
      <h2>Une équipe, trois expertises</h2>
      <p>Du brief à la mise en production, on couvre toute la chaîne — design, code, sécurité, monitoring.</p>
    </div>
    <div class="services-grid">
      <div class="card reveal">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </div>
        <h3>Création web sur-mesure</h3>
        <p>Sites vitrine, e-commerce, SaaS. Stack moderne (Next.js, Astro, Supabase), performance maximale, SEO inclus.</p>
      </div>
      <div class="card reveal">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Cybersécurité intégrée</h3>
        <p>Hardening serveur, WAF, anti-DDoS, headers de sécurité. Conformité OWASP & RGPD garantie.</p>
      </div>
      <div class="card reveal">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <h3>SOC / SIEM 24/7</h3>
        <p>Monitoring temps réel, détection d'intrusions, réponse à incident. Dashboard client transparent.</p>
      </div>
    </div>
    <div style="text-align:center;margin-top:var(--sp-6)">
      <a href="/services" class="btn btn-ghost">Voir tous nos services →</a>
    </div>
  </div>
</section>

<!-- ═══ MAQUETTES APERÇU ═══ -->
<section class="section" style="background:var(--surface-1);border-top:1px solid var(--border-1);border-bottom:1px solid var(--border-1)">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Réalisations</span>
      <h2>Nos dernières maquettes</h2>
      <p>Un aperçu de ce qu'on livre. Chaque site est livré avec son audit de sécurité.</p>
    </div>
    <div class="mockups-grid">
      <%
        const mockups = [
          { img: '/images/portfolio_bricosam.png', url: 'bricosam.fr', name: 'BricoSam', desc: 'Site vitrine artisan bricolage', tags: ['Next.js', 'Tailwind', 'CMS'] },
          { img: '/images/portfolio_commerce.png', url: 'shop.dhmtech.fr', name: 'DHM Shop', desc: 'E-commerce électronique B2B', tags: ['Astro', 'Stripe', 'PostgreSQL'] },
          { img: '/images/portfolio_dhmtech.png', url: 'dhmtech.fr', name: 'DHM Tech', desc: 'Plateforme SaaS technique', tags: ['Next.js', 'Supabase', 'Auth'] }
        ];
        mockups.forEach(m => {
      %>
        <article class="mockup reveal">
          <div class="mockup-img">
            <div class="browser-bar"><span></span><span></span><span></span><div class="url"><%= m.url %></div></div>
            <img src="<%= m.img %>" alt="Maquette <%= m.name %>" loading="lazy" onerror="this.style.display='none'" />
          </div>
          <div class="mockup-body">
            <div class="mockup-tags">
              <% m.tags.forEach(t => { %><span class="mockup-tag"><%= t %></span><% }) %>
            </div>
            <h3><%= m.name %></h3>
            <p><%= m.desc %></p>
            <div class="mockup-actions">
              <a href="/realisations" class="btn btn-secondary">Détails</a>
              <a href="https://<%= m.url %>" class="btn btn-ghost" target="_blank" rel="noopener">Voir le site ↗</a>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
    <div style="text-align:center;margin-top:var(--sp-6)">
      <a href="/realisations" class="btn btn-primary">Voir toutes les maquettes →</a>
    </div>
  </div>
</section>

<!-- ═══ POURQUOI ARKIS ═══ -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Notre approche</span>
      <h2>Pourquoi choisir Arkis ?</h2>
    </div>
    <div class="services-grid">
      <div class="card">
        <h3>Secure by Design</h3>
        <p>La sécurité n'est pas un patch après-coup : elle est intégrée à chaque décision technique, de l'architecture au déploiement.</p>
      </div>
      <div class="card">
        <h3>Transparence totale</h3>
        <p>Vous voyez en temps réel l'état de votre site, les attaques bloquées, les performances. Plus de boîte noire.</p>
      </div>
      <div class="card">
        <h3>Build &amp; Run</h3>
        <p>On ne livre pas et on disparaît. Maintenance, mises à jour de sécurité, support — on reste à vos côtés.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ CTA ═══ -->
<section class="section">
  <div class="container">
    <div class="cta-block">
      <h2>Prêt à passer au niveau supérieur ?</h2>
      <p>30 minutes d'audit offert pour comprendre vos besoins et vous proposer la meilleure approche. Sans engagement.</p>
      <a href="/contact" class="btn btn-lg">
        Réserver mon audit gratuit
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
