<%- include('partials/head', {
  title: 'Contact — Arkis',
  description: 'Démarrons votre projet. Audit gratuit, réponse sous 24h, basé en France.'
}) %>

<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <span class="eyebrow">Contact</span>
    <h1>Parlons de votre projet</h1>
    <p>Une question, un devis, un audit de sécurité ? Décrivez-nous votre besoin, on revient vers vous sous 24h ouvrées.</p>
  </div>
</section>

<section class="section">
  <div class="container" style="max-width:900px">
    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:var(--sp-6)" class="contact-layout">

      <!-- Infos -->
      <aside>
        <h3 style="font-size:1.125rem;margin-bottom:var(--sp-4)">Comment nous joindre</h3>
        <ul class="feature-list" style="margin:0">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <div><strong style="color:var(--text-1)">Email</strong><br/><a href="mailto:contact@arkis.agency">contact@arkis.agency</a></div>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <div><strong style="color:var(--text-1)">Téléphone</strong><br/>+33 1 23 45 67 89</div>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div><strong style="color:var(--text-1)">Adresse</strong><br/>Paris &amp; Toulouse, France</div>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <div><strong style="color:var(--text-1)">Réponse</strong><br/>Sous 24h ouvrées</div>
          </li>
        </ul>

        <div style="margin-top:var(--sp-6);padding:var(--sp-4);background:var(--surface-1);border-radius:var(--r-md);border:1px solid var(--border-1)">
          <div style="display:inline-flex;align-items:center;gap:6px;font-family:var(--font-mono);font-size:0.75rem;color:var(--ok);margin-bottom:6px">
            <span style="width:8px;height:8px;background:var(--ok);border-radius:50%;animation:pulseGlow 1.6s infinite"></span>
            Disponible aujourd'hui
          </div>
          <p style="margin:0;font-size:0.875rem">Réponse moyenne : <strong style="color:var(--text-1)">2h12</strong></p>
        </div>
      </aside>

      <!-- Form -->
      <div class="form-card">
        <form id="contact-form" novalidate>
          <div class="form-grid">
            <div class="field">
              <label for="cf-name">Nom complet *</label>
              <input id="cf-name" name="name" type="text" required autocomplete="name" />
            </div>
            <div class="field">
              <label for="cf-email">Email *</label>
              <input id="cf-email" name="email" type="email" required autocomplete="email" />
            </div>
            <div class="field">
              <label for="cf-company">Société</label>
              <input id="cf-company" name="company" type="text" autocomplete="organization" />
            </div>
            <div class="field">
              <label for="cf-subject">Sujet *</label>
              <select id="cf-subject" name="subject" required>
                <option value="">Choisir…</option>
                <option value="creation">Création de site</option>
                <option value="security">Cybersécurité / audit</option>
                <option value="pentest">Pen-test</option>
                <option value="soc">SOC managé</option>
                <option value="other">Autre</option>
              </select>
            </div>
            <div class="field full">
              <label for="cf-message">Votre message *</label>
              <textarea id="cf-message" name="message" rows="6" required placeholder="Décrivez votre projet, votre besoin, votre contexte…"></textarea>
            </div>
            <div class="full" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--sp-3)">
              <small style="color:var(--text-3);font-size:0.8125rem">Vos données ne sont jamais partagées. Voir notre <a href="/legal/politique-confidentialite">politique de confidentialité</a>.</small>
              <button type="submit" class="btn btn-primary btn-lg">
                Envoyer
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
