            </label>
          </div>

        </div>

        <!-- Telemetry & Score (Right side) -->
        <div class="hardening-stats" style="background: rgba(12, 21, 41, 0.6); border: 1px solid var(--clr-border); border-radius: var(--radius-lg); padding: 2.5rem; display: flex; flex-direction: column; gap: 2rem; position: sticky; top: 100px;">
          
          <div style="text-align: center;">
            <p class="font-mono" style="font-size: 0.8rem; color: var(--clr-text-3); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem;">Score Global de Durcissement</p>
            <div style="position: relative; width: 160px; height: 160px; margin: 0 auto; display: flex; align-items: center; justify-content: center;">
              <!-- Radial gauge SVG -->
              <svg width="160" height="160" viewBox="0 0 100 100" style="transform: rotate(-90deg);">
                <circle cx="50" cy="50" r="44" fill="none" stroke="rgba(255,255,255,0.02)" stroke-width="6"/>
                <circle id="hardening-radial-bar" cx="50" cy="50" r="44" fill="none" stroke="url(#hardGrad)" stroke-width="6" stroke-dasharray="276" stroke-dashoffset="138" stroke-linecap="round" style="transition: stroke-dashoffset 0.8s cubic-bezier(0.22, 1, 0.36, 1);"/>
                <defs>
                  <linearGradient id="hardGrad" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#00D4FF"/>
                    <stop offset="100%" stop-color="#7B2FFF"/>
                  </linearGradient>
                </defs>
              </svg>
              <div style="position: absolute; display: flex; flex-direction: column; align-items: center;">
                <span id="hardening-score-pct" style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 800; color: var(--clr-text); line-height: 1;">60%</span>
                <span class="font-mono" style="font-size: 0.65rem; color: var(--clr-cyan); text-transform: uppercase; margin-top: 0.25rem;">Résilience</span>
              </div>
            </div>
          </div>

          <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; text-align: center;">
            <div>
              <p class="font-mono" style="font-size: 0.7rem; color: var(--clr-text-3); text-transform: uppercase; margin-bottom: 0.25rem;">Menace Résiduelle</p>
              <span id="hardening-threat-level" style="font-size: 1rem; font-weight: 700; color: var(--clr-red); transition: color 0.4s;">Élevée ⚠️</span>
            </div>
            <div>
              <p class="font-mono" style="font-size: 0.7rem; color: var(--clr-text-3); text-transform: uppercase; margin-bottom: 0.25rem;">Niveau de SLA</p>
              <span id="hardening-sla" style="font-size: 1rem; font-weight: 700; color: var(--clr-text);">Standard</span>
            </div>
          </div>

          <!-- Explanation Card -->
