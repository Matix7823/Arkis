              <input type="checkbox" id="switch-csp" style="opacity: 0; width: 0; height: 0;" checked>
              <span class="cyber-slider" style="position: absolute; cursor: pointer; inset: 0; background-color: rgba(255,255,255,0.08); border: 1px solid var(--clr-border); border-radius: 34px; transition: .4s;"></span>
