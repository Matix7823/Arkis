  <section class="section" style="background:var(--clr-bg-2);border-top:1px solid var(--clr-border);padding:5rem 0;">
    <div class="container">
      <div class="section-header" style="text-align:center;margin-bottom:3.5rem;">
        <p class="section-tag reveal-up">Pourquoi Arkis ?</p>
        <h2 class="section-title reveal-up delay-1">Ce que nous faisons <span class="gradient-text">différemment.</span></h2>
        <p class="section-subtitle reveal-up delay-2" style="margin-inline:auto;">Chaque fonctionnalité est conçue pour protéger votre investissement et maximiser votre retour sur ROI numérique.</p>
      </div>

      <!-- Feature comparison table -->
      <div class="reveal-up delay-1" style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;min-width:700px;">
          <thead>
            <tr style="border-bottom:1px solid var(--clr-border);">
              <th style="text-align:left;padding:1rem 1.25rem;font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-text-3);text-transform:uppercase;letter-spacing:.06em;">Fonctionnalité</th>
              <th style="text-align:center;padding:1rem;font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-cyan);text-transform:uppercase;letter-spacing:.06em;">Arkis</th>
              <th style="text-align:center;padding:1rem;font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-text-3);text-transform:uppercase;letter-spacing:.06em;">Agence WordPress</th>
              <th style="text-align:center;padding:1rem;font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-text-3);text-transform:uppercase;letter-spacing:.06em;">Agence Classique</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ['Score PageSpeed', '100/100 garanti', '40–70/100', '60–85/100', 'cyan', false],
              ['Protection DDoS', '200 Tbps — Cloudflare Enterprise', 'Plugin basique', 'Selon hébergeur', 'cyan', false],
              ['Pen-Testing', 'Intégré dès le Build', 'Non inclus', 'En option, coûteux', 'red', false],
              ['CVE tracking', '0 garanti contractuellement', 'Non suivi', 'Non garanti', 'green', false],
              ['Support critique', 'CTO en astreinte — réponse 15min', 'Email 48h', 'Ticketing variable', 'cyan', false],
              ['Conformité RGPD', 'Natif — architecture Zero-Trust', 'Plugin payant', 'Juriste séparé', 'purple', false],
              ['Uptime SLA', '99.99% garanti — Edge CDN', 'Aucune garantie', 'Selon contrat', 'green', false],
              ['TCO 2 ans', 'Transparent, fixe, prévisible', 'Plugins + urgences', 'Devis ré-évalués', 'cyan', true],
            ].forEach(([feat, arkis, wp, classic, color, last]) => { %>
