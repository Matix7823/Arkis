  }
  .hardening-switch-card.active .hs-icon {
    color: var(--clr-cyan) !important;
    filter: drop-shadow(0 0 8px rgba(0, 212, 255, 0.4));
  }
  .cyber-switch input:checked + .cyber-slider {
    background: var(--grad-primary) !important;
