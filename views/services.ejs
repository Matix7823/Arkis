              <td style="padding:0.875rem 1.25rem;font-size:0.85rem;color:var(--clr-text-2);font-weight:500;"><%= feat %></td>
              <td style="padding:0.875rem 1rem;text-align:center;">
                <span style="font-size:0.8rem;font-weight:700;color:var(--clr-<%= color %>);">✓ <%= arkis %></span>
              </td>
              <td style="padding:0.875rem 1rem;text-align:center;font-size:0.78rem;color:var(--clr-text-3);"><%= wp %></td>
              <td style="padding:0.875rem 1rem;text-align:center;font-size:0.78rem;color:var(--clr-text-3);"><%= classic %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       INTERACTIVE HARDENING CONFIGURATOR
  ═══════════════════════════════════════════════ -->
  <section id="hardening" class="section hardening-section" style="border-top:1px solid var(--clr-border);padding:5rem 0;background:radial-gradient(circle at 20% 50%,rgba(0,212,255,0.03),transparent 50%);">
    <div class="container">
      <div class="section-header" style="text-align:center;margin-bottom:4rem;">
        <p class="section-tag reveal-up">Simulateur de Blindage</p>
        <h2 class="section-title reveal-up delay-1">Configurez votre <br/><span class="gradient-text">niveau de durcissement.</span></h2>
        <p class="section-subtitle reveal-up delay-2" style="margin-inline:auto;">Activez les protocoles de cybersécurité ci-dessous pour voir l'impact en temps réel sur la résilience et le score de blindage de votre future infrastructure.</p>
        <div class="interactive-hint reveal-up delay-3" style="margin-inline:auto;">
          <span class="hint-dot"></span>
          <span>Survolez ou activez les commutateurs pour obtenir des informations cyber détaillées</span>
        </div>
      </div>

      <div class="hardening-layout resp-grid-2" style="display:grid;grid-template-columns:1.2fr 1fr;gap:3rem;align-items:start;">

        <div class="hardening-controls" style="display:flex;flex-direction:column;gap:1.25rem;">

          <div class="hardening-switch-card" data-layer="hsts" style="background:var(--clr-bg-card);border:1px solid var(--clr-border);border-radius:var(--radius-md);padding:1.25rem;display:flex;align-items:center;justify-content:space-between;transition:all var(--t-base);cursor:pointer;">
            <div style="display:flex;gap:1rem;align-items:center;">
              <div class="hs-icon" style="color:var(--clr-cyan);flex-shrink:0;width:20px;height:20px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h4 style="font-size:1rem;font-weight:700;color:var(--clr-text);margin-bottom:.15rem;">HSTS (Strict Transport Security)</h4>
                <p style="font-size:0.8rem;color:var(--clr-text-2);">Force les connexions HTTPS chiffrées et prévient le downgrade vers HTTP.</p>
              </div>
            </div>
            <label class="cyber-switch" style="position:relative;display:inline-block;width:44px;height:24px;flex-shrink:0;">
              <input type="checkbox" id="switch-hsts" style="opacity:0;width:0;height:0;" checked>
              <span class="cyber-slider" style="position:absolute;cursor:pointer;inset:0;background-color:rgba(255,255,255,0.08);border:1px solid var(--clr-border);border-radius:34px;transition:.4s;"></span>
            </label>
          </div>

          <div class="hardening-switch-card" data-layer="csp" style="background:var(--clr-bg-card);border:1px solid var(--clr-border);border-radius:var(--radius-md);padding:1.25rem;display:flex;align-items:center;justify-content:space-between;transition:all var(--t-base);cursor:pointer;">
            <div style="display:flex;gap:1rem;align-items:center;">
              <div class="hs-icon" style="color:var(--clr-cyan);flex-shrink:0;width:20px;height:20px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              </div>
              <div>
                <h4 style="font-size:1rem;font-weight:700;color:var(--clr-text);margin-bottom:.15rem;">CSP (Content Security Policy) Stricte</h4>
                <p style="font-size:0.8rem;color:var(--clr-text-2);">Bloque l'exécution de scripts non approuvés — anti-XSS natif au niveau du navigateur.</p>
              </div>
            </div>
            <label class="cyber-switch" style="position:relative;display:inline-block;width:44px;height:24px;flex-shrink:0;">
              <input type="checkbox" id="switch-csp" style="opacity:0;width:0;height:0;" checked>
              <span class="cyber-slider" style="position:absolute;cursor:pointer;inset:0;background-color:rgba(255,255,255,0.08);border:1px solid var(--clr-border);border-radius:34px;transition:.4s;"></span>
            </label>
          </div>

          <div class="hardening-switch-card" data-layer="tls" style="background:var(--clr-bg-card);border:1px solid var(--clr-border);border-radius:var(--radius-md);padding:1.25rem;display:flex;align-items:center;justify-content:space-between;transition:all var(--t-base);cursor:pointer;">
            <div style="display:flex;gap:1rem;align-items:center;">
              <div class="hs-icon" style="color:var(--clr-cyan);flex-shrink:0;width:20px;height:20px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </div>
              <div>
