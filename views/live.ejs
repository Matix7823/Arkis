<%- include('partials/head', {
  title: 'Live SOC — Arkis SIEM Dashboard',
  description: 'Dashboard SOC/SIEM live : monitoring temps réel, détection des menaces, alertes, métriques.'
}) %>

<!-- Styles spécifiques au SIEM -->
<link rel="stylesheet" href="/siem.css">

<!-- On ferme la balise head et body ouverte par partials/head si besoin. En réalité partials/head n'ouvre pas le body, il contient juste le <head>. 
Wait, let's assume partials/head outputs just <head>...</head> or opens body. Let's use standard layout -->

</head>
<body class="siem-layout">

  <!-- Sidebar -->
  <aside class="siem-sidebar">
    <div class="siem-logo">
      <svg viewBox="0 0 32 32" fill="none"><path d="M6 26 L16 4 L26 26 L21 26 L16 14 L11 26 Z" fill="#22d3ee"/></svg>
      Arkis SIEM
    </div>
    <nav class="siem-nav">
      <a href="#" class="siem-nav-item active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        Dashboard
      </a>
      <a href="#" class="siem-nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        Live Events
      </a>
      <a href="#" class="siem-nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Threat Intel
      </a>
      <a href="#" class="siem-nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Reports
      </a>
    </nav>
    <div class="siem-sidebar-footer">
      <a href="/" class="btn-back">← Retour au site web</a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="siem-main">
    
    <!-- Topbar -->
    <header class="siem-topbar">
      <div class="topbar-left">
        <div class="tenant-selector">
          <strong>Tenant:</strong> demo-client.fr
        </div>
        <div class="tenant-selector" style="border:none;background:transparent;color:#8b949e">
          Region: EU-West
        </div>
      </div>
      <div class="topbar-right">
        <div class="time-range">
          <span class="live-indicator"></span>
          Live Monitoring
        </div>
        <div id="siem-clock" style="font-family:var(--font-mono);font-size:0.9rem">--:--:--</div>
      </div>
    </header>

    <!-- Dashboard Content -->
    <div class="siem-content">
      
      <!-- KPIs -->
      <div class="kpi-row">
        <div class="kpi-card">
          <div class="kpi-title">Events / Sec</div>
          <div class="kpi-value"><span id="siem-eps">0</span> <span class="kpi-unit">EPS</span></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-title">Threats Blocked (24h)</div>
          <div class="kpi-value"><span id="siem-blocked">0</span></div>
        </div>
        <div class="kpi-card" style="border-color: rgba(248,81,73,0.5)">
          <div class="kpi-title" style="color: var(--siem-crit)">Active Critical Alerts</div>
          <div class="kpi-value" style="color: var(--siem-crit)">3 <span class="kpi-unit">Needs Action</span></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-title">Uptime SLA</div>
          <div class="kpi-value">99.99 <span class="kpi-unit">%</span></div>
        </div>
      </div>

      <!-- Charts -->
      <div class="chart-row">
        <!-- Main Network Traffic -->
        <div class="panel">
          <div class="panel-header">Network Traffic (Live)</div>
          <div class="panel-body">
            <canvas id="trafficChart"></canvas>
          </div>
        </div>
        
        <!-- Threat Donut -->
        <div class="panel">
          <div class="panel-header">Threat Typology</div>
          <div class="panel-body">
            <canvas id="threatChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Live Event Stream -->
      <div class="panel" style="flex:1">
        <div class="panel-header">Live Event Stream</div>
        <div class="panel-body log-table-wrapper" style="padding:0">
          <table class="log-table">
            <thead>
              <tr>
                <th>Time</th>
                <th>Severity</th>
                <th>Source</th>
                <th>IP Address</th>
                <th>Event Message</th>
              </tr>
            </thead>
            <tbody id="log-tbody">
              <!-- Logs injectés via JS -->
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>

  <!-- Load Chart.js via CDN -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- Load SIEM Script -->
  <script src="/siem.js"></script>
</body>
</html>
