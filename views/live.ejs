<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Live SOC — Arkis SIEM</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cpath d='M6 26 L16 4 L26 26 L21 26 L16 14 L11 26 Z' fill='%2306b6d4'/%3E%3C/svg%3E" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Fira+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/siem.css?v=<%= typeof buildVersion !== 'undefined' ? buildVersion : Date.now() %>" />
</head>
<body class="siem-layout">

  <div class="demo-banner">
    <strong>DÉMO INTERACTIVE</strong>
    <span>Aperçu fictif du SIEM managé Arkis — données synthétiques en temps réel</span>
    <a href="/contact" class="demo-cta">Demander une démo réelle →</a>
  </div>

  <!-- ═══ SIDEBAR ═══ -->
  <aside class="siem-sidebar">
    <div class="siem-logo">
      <svg viewBox="0 0 32 32" width="22" height="22"><path d="M6 26 L16 4 L26 26 L21 26 L16 14 L11 26 Z" fill="#06b6d4"/></svg>
      <span>Arkis<span class="logo-suffix">SIEM</span></span>
    </div>

    <div class="sidebar-section-title">Surveillance</div>
    <nav class="siem-nav">
      <button class="siem-nav-item active" data-view="dashboard">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard <span class="nav-badge nav-badge-live">live</span>
      </button>
      <button class="siem-nav-item" data-view="events">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Flux d'événements
      </button>
      <button class="siem-nav-item" data-view="incidents">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Incidents <span class="nav-badge nav-badge-crit">3</span>
      </button>
      <button class="siem-nav-item" data-view="threatintel">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/></svg>
        Threat Intel
      </button>
      <button class="siem-nav-item" data-view="ueba">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        UEBA <span class="nav-badge nav-badge-warn">2</span>
      </button>
    </nav>

    <div class="sidebar-section-title">Gestion</div>
    <nav class="siem-nav">
      <button class="siem-nav-item" data-view="assets">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
        Assets <span class="nav-badge">247</span>
      </button>
      <button class="siem-nav-item" data-view="vulns">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Vulnérabilités <span class="nav-badge nav-badge-warn">17</span>
      </button>
      <button class="siem-nav-item" data-view="compliance">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Conformité
      </button>
      <button class="siem-nav-item" data-view="query">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        Query Console
      </button>
      <button class="siem-nav-item" data-view="reports">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Reports
      </button>
    </nav>

    <div class="sidebar-section-title">Système</div>
    <nav class="siem-nav">
      <button class="siem-nav-item" data-view="integrations">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        Intégrations <span class="nav-badge">24</span>
      </button>
      <button class="siem-nav-item" data-view="settings">
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Paramètres
      </button>
    </nav>

    <div class="siem-sidebar-footer">
      <div class="analyst-card">
        <div class="analyst-avatar">SA</div>
        <div class="analyst-info">
          <div class="analyst-name">S. Aubry — SOC L2</div>
          <div class="analyst-role">En ligne · Shift 08h–20h</div>
        </div>
        <span class="analyst-dot"></span>
      </div>
      <a href="/" class="btn-back">← Retour au site Arkis</a>
    </div>
  </aside>

  <!-- ═══ MAIN ═══ -->
  <main class="siem-main">
    <header class="siem-topbar">
      <div class="topbar-left">
        <div class="tenant-selector">
          <span class="tenant-label">Tenant</span>
          <strong id="topbar-tenant">demo-client.fr</strong>
          <span style="color:var(--siem-text-dim)">▾</span>
        </div>
        <div class="tenant-region"><span class="region-dot"></span> EU-West · Paris</div>
        <div class="search-box">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="global-search" placeholder="Rechercher : IP, asset, alerte, CVE…" autocomplete="off" />
          <span class="kbd">⌘K</span>
        </div>
      </div>
      <div class="topbar-right">
        <div class="time-range">
          <button class="time-btn">1h</button>
          <button class="time-btn active">24h</button>
          <button class="time-btn">7j</button>
          <button class="time-btn">30j</button>
        </div>
        <div class="live-pill"><span class="live-indicator"></span> LIVE</div>
        <div id="siem-clock" class="siem-clock">--:--:-- UTC</div>
        <button class="icon-btn" title="Notifications" aria-label="Notifications">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <span class="icon-badge">3</span>
        </button>
      </div>
    </header>

    <!-- ══════════════════════════════════════════════════
         VIEW: DASHBOARD
    ══════════════════════════════════════════════════ -->
    <section class="view active" id="view-dashboard">
      <div class="siem-content">

        <section class="kpi-row">
          <div class="kpi-card">
            <div class="kpi-head"><span class="kpi-title">Events / sec</span><span class="kpi-trend trend-up">▲ 12%</span></div>
            <div class="kpi-value"><span id="siem-eps">1 024</span><span class="kpi-unit">EPS</span></div>
            <div class="kpi-spark"><canvas id="sparkEps"></canvas></div>
          </div>
          <div class="kpi-card">
            <div class="kpi-head"><span class="kpi-title">Menaces bloquées 24h</span><span class="kpi-trend trend-up">▲ 8%</span></div>
            <div class="kpi-value"><span id="siem-blocked">48 391</span></div>
            <div class="kpi-spark"><canvas id="sparkBlocked"></canvas></div>
          </div>
          <div class="kpi-card kpi-crit">
            <div class="kpi-head"><span class="kpi-title">Incidents critiques</span><span class="kpi-trend trend-down">⚠ Action requise</span></div>
            <div class="kpi-value"><span>3</span><span class="kpi-unit">ouverts</span></div>
            <div class="kpi-sub">MTTR moyen : <strong>4m 12s</strong></div>
          </div>
          <div class="kpi-card">
            <div class="kpi-head"><span class="kpi-title">Score de menace</span><span class="kpi-trend trend-flat">→ stable</span></div>
            <div class="kpi-value"><span id="siem-score">38</span><span class="kpi-unit">/100</span></div>
            <div class="kpi-bar"><div class="kpi-bar-fill" id="siem-score-bar" style="width:38%;background:linear-gradient(90deg,#22c55e,#e3a008 55%,#f85149)"></div></div>
          </div>
          <div class="kpi-card">
            <div class="kpi-head"><span class="kpi-title">Assets supervisés</span><span class="kpi-trend trend-flat">→ stable</span></div>
            <div class="kpi-value"><span>247</span></div>
            <div class="kpi-sub"><span class="dot-ok"></span>244 sains &nbsp;<span class="dot-warn"></span>2 dégr. &nbsp;<span class="dot-crit"></span>1 offline</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-head"><span class="kpi-title">SLA disponibilité</span><span class="kpi-trend trend-up">▲ objectif</span></div>
            <div class="kpi-value"><span>99.99</span><span class="kpi-unit">%</span></div>
            <div class="kpi-sub">Contractuel : <strong>99.95%</strong></div>
          </div>
        </section>

        <section class="grid-2-1">
          <div class="panel">
            <div class="panel-header">
              <div><h3>Trafic réseau temps réel</h3><p class="panel-sub">Inbound · Outbound · Bloqué WAF</p></div>
              <div class="legend">
                <span><i style="background:#06b6d4"></i> Inbound</span>
                <span><i style="background:#8b5cf6"></i> Outbound</span>
                <span><i style="background:#f85149"></i> Bloqué</span>
              </div>
            </div>
            <div class="panel-body chart-canvas-wrap"><canvas id="trafficChart"></canvas></div>
          </div>
          <div class="panel">
            <div class="panel-header"><div><h3>Santé infrastructure</h3><p class="panel-sub">12 services critiques</p></div></div>
            <div class="panel-body health-grid">
              <div class="gauge"><div class="gauge-circle" style="--p:18"><span class="gauge-val">18%</span></div><div class="gauge-label">CPU</div></div>
              <div class="gauge"><div class="gauge-circle" style="--p:64"><span class="gauge-val">64%</span></div><div class="gauge-label">RAM</div></div>
              <div class="gauge"><div class="gauge-circle gauge-warn" style="--p:83"><span class="gauge-val">83%</span></div><div class="gauge-label">Disque</div></div>
              <div class="gauge"><div class="gauge-circle gauge-ok" style="--p:100"><span class="gauge-val">100%</span></div><div class="gauge-label">Uptime</div></div>
            </div>
          </div>
        </section>

        <section class="grid-2-1">
          <div class="panel">
            <div class="panel-header">
              <div><h3>Origine géographique des attaques</h3><p class="panel-sub">Sources actives · Arkis Threat Feed</p></div>
              <div class="legend"><span><i class="dot-crit"></i> Critique</span><span><i class="dot-warn"></i> Suspect</span><span><i class="dot-info"></i> Scan</span></div>
            </div>
            <div class="panel-body world-map-wrap">
              <svg viewBox="0 0 1000 500" class="world-map">
                <rect width="1000" height="500" fill="#0d1119" rx="4"/>
                <g fill="#161e2d" stroke="#1e2a3a" stroke-width="0.7">
                  <path d="M80,60 L220,55 L310,80 L340,160 L310,230 L260,270 L200,280 L160,240 L110,200 L70,140 Z"/>
                  <path d="M180,290 L240,285 L270,360 L250,440 L220,460 L200,420 L185,360 Z"/>
                  <path d="M430,70 L510,60 L550,90 L545,140 L510,160 L460,165 L430,130 Z"/>
                  <path d="M440,185 L530,180 L570,260 L560,380 L510,420 L460,400 L430,310 Z"/>
                  <path d="M540,50 L820,45 L880,90 L870,150 L800,175 L650,170 L570,130 Z"/>
                  <path d="M570,175 L700,175 L740,250 L700,300 L630,295 L580,240 Z"/>
                  <path d="M700,195 L830,200 L880,270 L850,330 L790,320 L730,270 Z"/>
                  <path d="M790,360 L890,355 L920,410 L870,440 L800,430 Z"/>
                </g>
                <g class="attack-lines" stroke-width="1.2" fill="none" opacity="0.6">
                  <path d="M490,110 Q420,170 230,210" stroke="#f85149"/>
                  <path d="M490,110 Q690,90 800,135" stroke="#e3a008"/>
                  <path d="M490,110 Q680,180 760,270" stroke="#f85149"/>
                  <path d="M490,110 Q370,200 270,320" stroke="#3b82f6"/>
                  <path d="M490,110 Q550,160 660,240" stroke="#f85149"/>
                </g>
                <circle cx="490" cy="110" r="5" fill="#06b6d4"/>
                <circle cx="490" cy="110" r="13" fill="none" stroke="#06b6d4" class="map-target-ring"/>
                <g class="attack-pts">
                  <circle cx="230" cy="210" r="5" fill="#f85149" class="atk-dot"/><text x="240" y="208" fill="#7a8798" font-size="9" font-family="Fira Sans">USA · 3 219</text>
                  <circle cx="800" cy="135" r="6" fill="#e3a008" class="atk-dot"/><text x="714" y="130" fill="#7a8798" font-size="9" font-family="Fira Sans">RU · 2 847</text>
                  <circle cx="760" cy="270" r="6" fill="#f85149" class="atk-dot"/><text x="680" y="295" fill="#7a8798" font-size="9" font-family="Fira Sans">CN · 4 012</text>
                  <circle cx="660" cy="240" r="5" fill="#f85149" class="atk-dot"/><text x="668" y="238" fill="#7a8798" font-size="9" font-family="Fira Sans">IR · 1 024</text>
                </g>
              </svg>
              <div class="map-stats">
                <div><strong>12 114</strong><span>menaces</span></div>
                <div><strong>58</strong><span>pays</span></div>
                <div><strong>100%</strong><span>bloquées</span></div>
              </div>
            </div>
          </div>
          <div class="panel">
            <div class="panel-header"><div><h3>Distribution alertes 24h</h3><p class="panel-sub">Sévérité horaire</p></div></div>
            <div class="panel-body chart-canvas-wrap"><canvas id="severityChart"></canvas></div>
          </div>
        </section>

        <section class="grid-3">
          <div class="panel">
            <div class="panel-header"><div><h3>Typologie des menaces</h3><p class="panel-sub">24h</p></div></div>
            <div class="panel-body chart-canvas-wrap" style="min-height:240px"><canvas id="threatChart"></canvas></div>
          </div>
          <div class="panel">
            <div class="panel-header"><div><h3>Top 5 attaquants</h3><p class="panel-sub">Score Threat Intel</p></div></div>
            <div class="panel-body">
              <div class="hbar-list">
                <div class="hbar-row"><div class="hbar-label"><code>185.220.101.42</code><span class="flag">RU</span></div><div class="hbar-track"><div class="hbar-fill bar-crit" style="width:96%"></div></div><div class="hbar-val">3 219</div></div>
                <div class="hbar-row"><div class="hbar-label"><code>194.180.49.114</code><span class="flag">CN</span></div><div class="hbar-track"><div class="hbar-fill bar-crit" style="width:79%"></div></div><div class="hbar-val">2 541</div></div>
                <div class="hbar-row"><div class="hbar-label"><code>91.204.212.170</code><span class="flag">IR</span></div><div class="hbar-track"><div class="hbar-fill bar-crit" style="width:65%"></div></div><div class="hbar-val">2 088</div></div>
                <div class="hbar-row"><div class="hbar-label"><code>45.142.214.219</code><span class="flag">US</span></div><div class="hbar-track"><div class="hbar-fill bar-warn" style="width:48%"></div></div><div class="hbar-val">1 547</div></div>
                <div class="hbar-row"><div class="hbar-label"><code>103.21.244.0</code><span class="flag">IN</span></div><div class="hbar-track"><div class="hbar-fill bar-info" style="width:26%"></div></div><div class="hbar-val">838</div></div>
              </div>
            </div>
          </div>
          <div class="panel">
            <div class="panel-header"><div><h3>Endpoints ciblés</h3><p class="panel-sub">Top URLs bloquées</p></div></div>
            <div class="panel-body">
              <div class="hbar-list">
                <div class="hbar-row"><div class="hbar-label"><code>/wp-login.php</code></div><div class="hbar-track"><div class="hbar-fill bar-crit" style="width:94%"></div></div><div class="hbar-val">4 218</div></div>
                <div class="hbar-row"><div class="hbar-label"><code>/api/auth/login</code></div><div class="hbar-track"><div class="hbar-fill bar-crit" style="width:74%"></div></div><div class="hbar-val">3 331</div></div>
                <div class="hbar-row"><div class="hbar-label"><code>/.env</code></div><div class="hbar-track"><div class="hbar-fill bar-warn" style="width:51%"></div></div><div class="hbar-val">2 294</div></div>
                <div class="hbar-row"><div class="hbar-label"><code>/api/users?id=</code></div><div class="hbar-track"><div class="hbar-fill bar-warn" style="width:38%"></div></div><div class="hbar-val">1 712</div></div>
                <div class="hbar-row"><div class="hbar-label"><code>/.git/config</code></div><div class="hbar-track"><div class="hbar-fill bar-info" style="width:21%"></div></div><div class="hbar-val">944</div></div>
              </div>
            </div>
          </div>
        </section>

        <section class="panel">
          <div class="panel-header">
            <div><h3>MITRE ATT&amp;CK — Couverture</h3><p class="panel-sub">14 tactiques · 112 techniques surveillées</p></div>
            <div class="legend">
              <span><i style="background:#0d1119;border:1px solid #1e2a3a"></i> Aucun</span>
              <span><i style="background:rgba(6,182,212,0.2)"></i> Bas</span>
              <span><i style="background:rgba(227,160,8,0.4)"></i> Moyen</span>
              <span><i style="background:rgba(248,81,73,0.5)"></i> Élevé</span>
            </div>
          </div>
          <div class="panel-body"><div class="mitre-grid" id="mitreGrid"></div></div>
        </section>

        <section class="panel">
          <div class="panel-header">
            <div><h3>Incidents actifs</h3><p class="panel-sub">Tickets SOC Arkis</p></div>
            <div class="header-actions">
              <button class="hd-btn" onclick="switchView('incidents')">Voir tous →</button>
              <button class="hd-btn hd-btn-primary">+ Nouveau</button>
            </div>
          </div>
          <div class="panel-body" style="padding:0;overflow:auto">
            <table class="incidents-table">
              <thead><tr><th>ID</th><th>Sév.</th><th>Titre</th><th>Asset</th><th>MITRE</th><th>Statut</th><th>Assigné</th><th>Ouvert</th></tr></thead>
