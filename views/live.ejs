<%- include('partials/head', { 
  title: 'SIEM Cyber-Défense en Direct (SOC) — Arkis Agency', 
  description: 'Console d\'observabilité de sécurité en temps réel. Suivez le pare-feu applicatif (WAF), la télémétrie des serveurs et les menaces DDoS déjouées en direct.' 
}) %>

<%- include('partials/header', { page: 'live' }) %>

<main style="padding-top: var(--nav-h); min-height: 100vh; background-color: var(--clr-bg); color: var(--clr-text);">
  
  <!-- ═══════════════════════════════════════════════
       LIVE SIEM CYBER-OBSERVABILITY SUITE (SOC)
       ═══════════════════════════════════════════════ -->
  <section class="section live-soc" style="background-image: var(--grad-glow); padding-bottom: 6rem; position: relative;">
    
    <!-- Cyber grid pattern inside the background -->
    <div style="position: absolute; inset: 0; background-image: radial-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      
      <!-- Dashboard Top Header Bar -->
      <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 2rem; margin-bottom: 3rem; flex-wrap: wrap; position: relative; z-index: 2;">
        <div>
          <div class="live-indicator" style="display: inline-flex; align-items: center; gap: 0.625rem; background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.25); padding: 0.4rem 1rem; border-radius: 100px; margin-bottom: 1rem;">
            <span style="width: 8px; height: 8px; background: var(--clr-green); border-radius: 50%; display: inline-block; animation: pulseGlow 1.5s infinite;" id="soc-status-dot"></span>
            <span class="font-mono" style="font-size: 0.78rem; color: var(--clr-green); font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;" id="soc-status-text">SYSTEM OPERATIONAL — DEFCON 4</span>
          </div>
          <h1 style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.03em;">
            SIEM Security <span class="gradient-text">Operations Center.</span>
          </h1>
          <p style="font-size: 0.95rem; color: var(--clr-text-2); max-width: 680px; margin-top: 0.75rem;">
            Console d'observabilité active et de télémétrie défensive d'Arkis. Surveillez en temps réel les flux réseau, l'intégrité de la JAMstack et les requêtes filtrées à l'Edge par notre WAF.
          </p>
        </div>

        <!-- Defcon Security Advisory Shield -->
        <div style="background: rgba(8, 15, 34, 0.8); border: 1px solid rgba(0, 212, 255, 0.2); border-radius: 16px; padding: 1rem 1.5rem; display: flex; align-items: center; gap: 1.25rem; box-shadow: var(--shadow-card);" id="defcon-shield">
          <div style="width: 48px; height: 48px; background: rgba(0, 212, 255, 0.08); border: 1.5px solid var(--clr-cyan); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--clr-cyan); animation: float 3s ease-in-out infinite;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--clr-text-3); text-transform: uppercase; display: block; letter-spacing: 0.05em;">Indice de Menace Global</span>
            <span style="font-family: var(--font-mono); font-size: 1.15rem; font-weight: 800; color: var(--clr-cyan);" id="threat-level-val">NORMAL (0.02%)</span>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════
           SIEM COMMAND CONTROLS & EXPLOIT PLAYGROUND
           ═══════════════════════════════════════════════ -->
      <div style="background: rgba(12, 21, 41, 0.6); border: 1px solid rgba(0, 212, 255, 0.15); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 2.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; backdrop-filter: blur(10px); position: relative; z-index: 2; box-shadow: 0 0 30px rgba(0, 212, 255, 0.05);" class="exploit-grid">
        
        <!-- Left: Quick presets and custom exploit sandbox -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div>
            <h3 style="font-size: 1.1rem; font-weight: 700; font-family: var(--font-display); color: var(--clr-text); margin-bottom: 0.25rem; display: flex; align-items: center; gap: 0.5rem;">
              <span style="display:inline-block; width:8px; height:8px; background:var(--clr-red); border-radius:50%; animation: pulseGlow 1s infinite;"></span>
              Cyber Attack Exploit Sandbox
            </h3>
            <p style="font-size: 0.8rem; color: var(--clr-text-2);">Testez l'impénétrabilité de nos systèmes. Choisissez un vecteur d'attaque ci-dessous, ajustez le payload et déclenchez l'offensive pour monitorer le WAF.</p>
          </div>

          <!-- Payload type selector -->
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label for="exploit-vector" style="font-size: 0.75rem; font-family: var(--font-mono); color: var(--clr-cyan); text-transform: uppercase; font-weight: 600;">Vecteur d'Attaque</label>
            <select id="exploit-vector" style="width: 100%; padding: 0.65rem 1rem; background: var(--clr-bg-2); border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: var(--clr-text); font-size: 0.85rem; font-weight: 500; outline: none; cursor: pointer; transition: border-color var(--t-fast);">
              <option value="sqli">Injection SQL — Authentification Bypass Presets</option>
              <option value="xss">Cross-Site Scripting (XSS) — Cookie Grabber Alert</option>
              <option value="bot">Bad Bot User-Agent — Web Server Scraper Crawler</option>
              <option value="custom">Payload Perso (Saisissez votre propre code malveillant)</option>
            </select>
          </div>

          <!-- Payload input textarea -->
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label for="exploit-payload" style="font-size: 0.75rem; font-family: var(--font-mono); color: var(--clr-cyan); text-transform: uppercase; font-weight: 600;">Code du Payload Offensif</label>
            <textarea id="exploit-payload" rows="3" style="width: 100%; padding: 0.75rem 1rem; background: #020612; border: 1px solid rgba(0, 212, 255, 0.15); border-radius: var(--radius-sm); color: #C084FC; font-family: var(--font-mono); font-size: 0.8rem; line-height: 1.4; outline: none; resize: none; transition: border-color 0.2s;" placeholder="' OR '1'='1' --"></textarea>
          </div>

          <!-- Action and status triggers -->
          <div style="display: flex; gap: 1rem; align-items: center;">
            <button id="btn-fire-exploit" class="btn btn-primary" style="background: var(--clr-red); border-color: var(--clr-red); color: white; display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1.25rem; font-size: 0.85rem; font-weight: 700; box-shadow: 0 0 15px rgba(239, 68, 68, 0.25);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Lancer l'Attaque
            </button>
            <span style="font-size: 0.75rem; font-family: var(--font-mono); color: var(--clr-text-3);" id="sandbox-status-text">Prêt à l'envoi</span>
          </div>

        </div>

        <!-- Right: Real-time Firewall Intercept Telemetry & Quick triggers -->
        <div style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.03); border-radius: var(--radius-md); padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between; gap: 1.5rem;">
          
          <div>
            <h4 style="font-size: 0.8rem; font-family: var(--font-mono); color: var(--clr-text-3); text-transform: uppercase; margin-bottom: 1rem; letter-spacing: 0.05em; display: flex; justify-content: space-between;">
              <span>Rapport de Filtration Edge</span>
              <span id="sandbox-result-badge" style="color:var(--clr-green); font-weight: 800;">● SHIELD ON</span>
            </h4>
            
            <div style="display: flex; flex-direction: column; gap: 0.75rem; font-family: var(--font-mono); font-size: 0.75rem;">
              <div style="display:flex; justify-content:space-between; border-bottom: 1px dashed rgba(255,255,255,0.04); padding-bottom: 0.4rem;">
                <span style="color:var(--clr-text-2);">Dernier Verdict WAF :</span>
                <strong id="waf-verdict" style="color:var(--clr-green);">PASS (Légitime)</strong>
              </div>
              <div style="display:flex; justify-content:space-between; border-bottom: 1px dashed rgba(255,255,255,0.04); padding-bottom: 0.4rem;">
                <span style="color:var(--clr-text-2);">Action Déclenchée :</span>
                <strong id="waf-action" style="color:var(--clr-text-3);">MONITOR ONLY</strong>
              </div>
              <div style="display:flex; justify-content:space-between;">
                <span style="color:var(--clr-text-2);">Signature de Risque :</span>
                <strong id="waf-signature" style="color:var(--clr-text-3);">NONE (0x000)</strong>
              </div>
            </div>
          </div>

          <!-- Quick simulation buttons at the bottom -->
          <div>
            <h4 style="font-size: 0.75rem; font-family: var(--font-mono); color: var(--clr-text-3); text-transform: uppercase; margin-bottom: 0.75rem; letter-spacing: 0.05em;">Scénarios d'Attaque Globaux (Auto)</h4>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
              <button id="btn-sim-ddos" class="btn btn-xs btn-outline" style="border-color: rgba(239, 68, 68, 0.3); color: #F87171; display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.72rem; padding: 0.35rem 0.65rem; background: rgba(239, 68, 68, 0.02);">
                <span style="width: 4px; height: 4px; background: #EF4444; border-radius: 50%;"></span>
                DDoS Flood
              </button>
              <button id="btn-sim-sqli" class="btn btn-xs btn-outline" style="border-color: rgba(167, 139, 250, 0.3); color: #C084FC; display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.72rem; padding: 0.35rem 0.65rem; background: rgba(167, 139, 250, 0.02);">
                <span style="width: 4px; height: 4px; background: #A78BFA; border-radius: 50%;"></span>
                Auto SQLi
              </button>
              <button id="btn-sim-bot" class="btn btn-xs btn-outline" style="border-color: rgba(0, 212, 255, 0.3); color: var(--clr-cyan); display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.72rem; padding: 0.35rem 0.65rem; background: rgba(0, 212, 255, 0.02);">
                <span style="width: 4px; height: 4px; background: var(--clr-cyan); border-radius: 50%;"></span>
                Bot Scan
              </button>
            </div>
          </div>

        </div>

      </div>

      <!-- Grid: Global Stats Counters -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--gap-card); margin-bottom: 2.5rem; position: relative; z-index: 2;">
        
        <!-- Attaques déjouées -->
        <div style="background: var(--clr-bg-card); border: 1px solid var(--clr-border); border-radius: var(--radius-lg); padding: 1.75rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; position: relative; overflow: hidden; box-shadow: var(--shadow-card);">
          <span style="font-size: 0.72rem; color: var(--clr-text-3); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: space-between;">
            <span>Menaces Bloquées (24H)</span>
            <span style="color: var(--clr-red);">● DÉFENSE ACTIONS</span>
          </span>
          <span class="font-mono" id="val-attacks" style="font-size: 2.5rem; font-weight: 800; color: var(--clr-red); letter-spacing: -0.03em; line-height: 1;">28,491</span>
          <span style="font-size: 0.72rem; color: var(--clr-text-2); display: flex; align-items: center; gap: 0.35rem;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg>
            <span id="txt-attacks-rate">+42 / min standard</span>
          </span>
          <div style="position: absolute; bottom: 0; left: 0; height: 3px; width: 100%; background: var(--clr-red); opacity: 0.6;" id="bar-attacks"></div>
        </div>

        <!-- Disponibilité Edge -->
        <div style="background: var(--clr-bg-card); border: 1px solid var(--clr-border); border-radius: var(--radius-lg); padding: 1.75rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; position: relative; overflow: hidden; box-shadow: var(--shadow-card);">
          <span style="font-size: 0.72rem; color: var(--clr-text-3); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: space-between;">
            <span>Uptime Réseau Edge</span>
            <span style="color: var(--clr-green);">● EDGE CLUSTERS</span>
          </span>
          <span class="font-mono" style="font-size: 2.5rem; font-weight: 800; color: var(--clr-green); letter-spacing: -0.03em; line-height: 1;" id="val-uptime">99.993%</span>
          <span style="font-size: 0.72rem; color: var(--clr-text-2); display: flex; align-items: center; gap: 0.35rem;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Multi-régions Cloudflare actif</span>
          </span>
          <div style="position: absolute; bottom: 0; left: 0; height: 3px; width: 100%; background: var(--clr-green); opacity: 0.6;"></div>
        </div>

        <!-- Temps de réponse -->
        <div style="background: var(--clr-bg-card); border: 1px solid var(--clr-border); border-radius: var(--radius-lg); padding: 1.75rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; position: relative; overflow: hidden; box-shadow: var(--shadow-card);">
          <span style="font-size: 0.72rem; color: var(--clr-text-3); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: space-between;">
            <span>Temps de Réponse Moyen</span>
            <span style="color: var(--clr-cyan);">● PROXIMITY EDGE</span>
          </span>
          <span class="font-mono" id="val-latency" style="font-size: 2.5rem; font-weight: 800; color: var(--clr-cyan); letter-spacing: -0.03em; line-height: 1;">82ms</span>
          <span style="font-size: 0.72rem; color: var(--clr-text-2); display: flex; align-items: center; gap: 0.35rem;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Routage DNS CDN intelligent</span>
          </span>
          <div style="position: absolute; bottom: 0; left: 0; height: 3px; width: 100%; background: var(--clr-cyan); opacity: 0.6;"></div>
        </div>

        <!-- Trafic légitime -->
        <div style="background: var(--clr-bg-card); border: 1px solid var(--clr-border); border-radius: var(--radius-lg); padding: 1.75rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; position: relative; overflow: hidden; box-shadow: var(--shadow-card);">
          <span style="font-size: 0.72rem; color: var(--clr-text-3); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: space-between;">
            <span>Trafic Total (24H)</span>
            <span style="color: var(--clr-text-2);">● HTTP REQUESTS</span>
          </span>
          <span class="font-mono" id="val-traffic" style="font-size: 2.5rem; font-weight: 800; color: var(--clr-text); letter-spacing: -0.03em; line-height: 1;">148,932</span>
          <span style="font-size: 0.72rem; color: var(--clr-text-2); display: flex; align-items: center; gap: 0.35rem;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>Visiteurs uniques vérifiés</span>
          </span>
          <div style="position: absolute; bottom: 0; left: 0; height: 3px; width: 100%; background: rgba(255,255,255,0.08); opacity: 0.4;"></div>
        </div>

      </div>

      <!-- MAIN SIEM LAYOUT: Charts & Live logs split -->
      <div style="display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 2rem; margin-bottom: 4rem; align-items: start; position: relative; z-index: 2;" class="siem-grid-layout">
        
        <!-- Left Column: Observability Console & Graphs -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          
          <!-- Panel 1: Cyber Observability Live Console -->
          <div style="background: #020612; border: 1px solid rgba(0, 212, 255, 0.15); border-radius: var(--radius-lg); overflow: hidden; box-shadow: 0 0 30px rgba(0, 212, 255, 0.08);">
            
            <!-- Terminal Header -->
            <div style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
              <div style="display:flex; align-items:center; gap: 0.5rem;">
                <span style="width: 8px; height: 8px; background:#EF4444; border-radius:50%;"></span>
                <span style="width: 8px; height: 8px; background:#F59E0B; border-radius:50%;"></span>
                <span style="width: 8px; height: 8px; background:#10B981; border-radius:50%;"></span>
                <span class="font-mono" style="font-size: 0.78rem; color: var(--clr-text-2); margin-left: 0.5rem; font-weight: 600;">arkis_waf_siem_core.log</span>
              </div>
              
              <!-- Console Filter Tabs -->
              <div style="display: flex; gap: 0.35rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 0.2rem; border-radius: 8px;" id="console-filter-tabs">
                <button class="filter-tab active" data-filter="ALL" style="background: rgba(0,212,255,0.1); border: none; color: #fff; font-family: var(--font-mono); font-size: 0.65rem; padding: 0.25rem 0.6rem; border-radius: 5px; cursor: pointer; font-weight: 600; transition: all 0.2s;">TOUT</button>
                <button class="filter-tab" data-filter="BLOCKED" style="background: transparent; border: none; color: var(--clr-text-3); font-family: var(--font-mono); font-size: 0.65rem; padding: 0.25rem 0.6rem; border-radius: 5px; cursor: pointer; font-weight: 600; transition: all 0.2s;">WAF BLOQUÉS</button>
                <button class="filter-tab" data-filter="INFO" style="background: transparent; border: none; color: var(--clr-text-3); font-family: var(--font-mono); font-size: 0.65rem; padding: 0.25rem 0.6rem; border-radius: 5px; cursor: pointer; font-weight: 600; transition: all 0.2s;">LÉGITIMES</button>
              </div>
            </div>
            
            <!-- Terminal Syslog Body -->
            <div class="console-body font-mono" id="cyber-console" style="padding: 1.5rem; height: 420px; overflow-y: auto; font-size: 0.78rem; line-height: 1.65; color: #94A3B8; scroll-behavior: smooth; scrollbar-width: thin; scrollbar-color: rgba(0, 212, 255, 0.2) transparent;">
              <p style="color: var(--clr-text-3); border-bottom: 1px dashed rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">[SIEM SYSLOG SYSTEM COMPILE SUCCESSFUL ... CAPTURE ACTIVE]</p>
              <div id="log-container">
                <!-- Live logs stream injected by JS -->
              </div>
            </div>
          </div>

          <!-- Panel 2: Live Graphic Threat Telemetry (SVG Chart Panel) -->
          <div style="background: var(--clr-bg-card); border: 1px solid var(--clr-border); border-radius: var(--radius-lg); padding: 1.5rem 2rem; box-shadow: var(--shadow-card);">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.75rem; margin-bottom: 1.25rem;">
              <h3 style="font-size: 1rem; font-weight: 700; color: var(--clr-text); font-family: var(--font-display); display: flex; align-items: center; gap: 0.5rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--clr-cyan)" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                Débit &amp; Activité Réseau Edge (Temps réel)
              </h3>
              <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--clr-cyan); background: var(--clr-cyan-dim); padding: 0.15rem 0.5rem; border-radius: 4px;">WAF TELEMETRY FEED</span>
            </div>
            
            <!-- Beautiful animated line SVG chart representing LCP / requests throughput -->
            <div style="width: 100%; height: 180px; position: relative;">
              <svg width="100%" height="100%" viewBox="0 0 600 180" preserveAspectRatio="none" style="overflow: visible;" id="chart-svg">
                <!-- Grids -->
                <line x1="0" y1="30" x2="600" y2="30" stroke="rgba(255,255,255,0.03)" stroke-width="1" />
                <line x1="0" y1="75" x2="600" y2="75" stroke="rgba(255,255,255,0.03)" stroke-width="1" />
                <line x1="0" y1="120" x2="600" y2="120" stroke="rgba(255,255,255,0.03)" stroke-width="1" />
                <line x1="0" y1="165" x2="600" y2="165" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
                
                <!-- Area and Line plots (Dynamic SVG paths styled to animate nicely) -->
                <path d="M 0 165 C 50 140, 100 150, 150 110 C 200 90, 250 120, 300 80 C 350 70, 400 140, 450 95 C 500 50, 550 80, 600 45 L 600 165 L 0 165 Z" fill="url(#chartGrad)" opacity="0.12" id="chart-area-path"></path>
                <path d="M 0 165 C 50 140, 100 150, 150 110 C 200 90, 250 120, 300 80 C 350 70, 400 140, 450 95 C 500 50, 550 80, 600 45" fill="none" stroke="var(--clr-cyan)" stroke-width="2.5" id="chart-line-path"></path>
                
                <!-- DDoS Threat Spike path (Drawn dynamically or hidden under normal conditions) -->
                <path d="" fill="none" stroke="#EF4444" stroke-width="2" stroke-dasharray="4 4" id="chart-spike-path" opacity="0"></path>

                <!-- Gradient Definitions -->
                <defs>
                  <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#00D4FF"></stop>
                    <stop offset="100%" stop-color="#00D4FF" stop-opacity="0"></stop>
                  </linearGradient>
                </defs>
              </svg>
              
              <!-- Floating label markers -->
