<%- include('partials/head', {
  title: 'Live SOC — Arkis SIEM Dashboard',
  description: 'Dashboard SOC/SIEM live : monitoring temps réel, détection des menaces, alertes, métriques. Démo d\'un vrai centre opérationnel de sécurité.'
}) %>

<%- include('partials/header') %>

<div class="soc-shell">

  <!-- Header du SOC -->
  <div class="soc-header">
    <div>
      <h1 class="soc-title">Security Operations Center</h1>
      <div class="soc-subtitle">Tenant: <span style="color:var(--accent-2)">demo-client.fr</span> · Region: EU-West · v2.5.0</div>
    </div>
    <div class="soc-header-right">
      <span class="soc-status-pill"><span class="dot"></span>All Systems Operational</span>
      <span class="soc-clock" id="soc-clock">--:--:--</span>
    </div>
  </div>

  <!-- KPIs en haut -->
  <div class="soc-kpis">
    <div class="kpi">
      <div class="kpi-label">Events / sec</div>
      <div class="kpi-value"><span id="kpi-eps">847</span> <span class="delta up">+12%</span></div>
      <svg class="kpi-spark" viewBox="0 0 100 30" preserveAspectRatio="none">
        <polyline points="0,22 10,18 20,20 30,14 40,16 50,10 60,12 70,8 80,10 90,4 100,6"
                  fill="none" stroke="#22d3ee" stroke-width="2"/>
      </svg>
    </div>
    <div class="kpi">
      <div class="kpi-label">Threats blocked / 24h</div>
      <div class="kpi-value"><span id="kpi-blocked">12,847</span> <span class="delta up">+18%</span></div>
      <svg class="kpi-spark" viewBox="0 0 100 30" preserveAspectRatio="none">
        <polyline points="0,28 10,24 20,20 30,22 40,14 50,18 60,10 70,12 80,4 90,8 100,2"
                  fill="none" stroke="#34d399" stroke-width="2"/>
      </svg>
    </div>
    <div class="kpi critical">
      <div class="kpi-label">Active critical</div>
      <div class="kpi-value"><span id="kpi-crit">3</span> <span class="delta down">-2</span></div>
      <svg class="kpi-spark" viewBox="0 0 100 30" preserveAspectRatio="none">
        <polyline points="0,8 10,12 20,6 30,18 40,16 50,10 60,20 70,14 80,22 90,18 100,20"
                  fill="none" stroke="#fca5a5" stroke-width="2"/>
      </svg>
    </div>
    <div class="kpi">
      <div class="kpi-label">Uptime SLA</div>
      <div class="kpi-value">99.99<span style="font-size:1rem;color:#64748b">%</span></div>
      <svg class="kpi-spark" viewBox="0 0 100 30" preserveAspectRatio="none">
        <polyline points="0,6 10,8 20,6 30,4 40,6 50,4 60,6 70,4 80,6 90,4 100,4"
                  fill="none" stroke="#818cf8" stroke-width="2"/>
      </svg>
    </div>
    <div class="kpi">
      <div class="kpi-label">Mean response</div>
      <div class="kpi-value">142<span style="font-size:1rem;color:#64748b">ms</span></div>
      <svg class="kpi-spark" viewBox="0 0 100 30" preserveAspectRatio="none">
        <polyline points="0,12 10,14 20,10 30,12 40,8 50,10 60,6 70,8 80,4 90,6 100,4"
                  fill="none" stroke="#fcd34d" stroke-width="2"/>
      </svg>
    </div>
  </div>

  <!-- Grid principale : Logs + Attack Map -->
  <div class="soc-grid">

    <!-- Live logs feed -->
    <div class="panel">
      <div class="panel-head">
        <div class="panel-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          Live Event Stream
          <span class="live-tag">LIVE</span>
        </div>
        <div class="panel-tools">
          <button class="panel-tool active" data-filter="all">All</button>
          <button class="panel-tool" data-filter="crit">Crit</button>
          <button class="panel-tool" data-filter="warn">Warn</button>
          <button class="panel-tool" data-filter="info">Info</button>
        </div>
      </div>
      <div class="panel-body">
        <div class="log-feed" id="log-feed" role="log" aria-live="polite"></div>
      </div>
    </div>

    <!-- Attack map -->
    <div class="panel">
      <div class="panel-head">
        <div class="panel-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Global Threat Map
        </div>
        <div class="panel-tools"><span class="panel-tool">EU-W1</span></div>
      </div>
      <div class="panel-body" style="padding:0">
        <div class="map-wrap" id="map-wrap">
          <svg class="map-svg" id="map-svg" viewBox="0 0 1000 500" preserveAspectRatio="xMidYMid meet">
            <defs>
              <linearGradient id="arcGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#ef4444" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#22d3ee" stop-opacity="0.4"/>
              </linearGradient>
            </defs>
            <!-- Simplified world continents (stylized) -->
            <path d="M150,180 Q220,140 280,170 Q340,200 320,240 Q280,260 220,250 Q170,230 150,180 Z"/>
            <path d="M380,150 Q480,130 540,160 Q580,200 560,240 Q520,260 460,250 Q400,230 380,200 Q380,170 380,150 Z"/>
            <path d="M580,180 Q700,160 800,180 Q860,210 840,250 Q780,270 700,260 Q620,240 580,210 Z"/>
            <path d="M200,290 Q260,280 310,300 Q340,340 320,380 Q280,400 240,390 Q210,360 200,290 Z"/>
            <path d="M440,290 Q520,290 580,310 Q600,360 580,400 Q520,420 470,410 Q440,370 440,290 Z"/>
            <path d="M720,300 Q800,300 850,330 Q860,380 830,400 Q780,410 740,400 Q710,360 720,300 Z"/>
            <!-- Target (your server) -->
            <circle cx="430" cy="190" r="4" fill="#22d3ee"/>
            <!-- Attack arcs -->
            <g id="attack-arcs"></g>
          </svg>
          <div class="map-target" style="top:38%; left:43%"></div>
          <div class="map-pulse" style="top:25%; left:18%"></div>
          <div class="map-pulse" style="top:35%; left:78%" id="map-pulse-2"></div>
          <div class="map-pulse" style="top:62%; left:25%" id="map-pulse-3"></div>
          <div class="map-pulse" style="top:55%; left:72%" id="map-pulse-4"></div>
          <div style="position:absolute;bottom:12px;left:14px;font-family:var(--font-mono);font-size:0.7rem;color:#94a3b8">
            <span style="display:inline-flex;align-items:center;gap:6px"><span style="width:8px;height:8px;border-radius:50%;background:#22d3ee;display:inline-block"></span>Your assets · 1</span>
            &nbsp;&nbsp;
            <span style="display:inline-flex;align-items:center;gap:6px"><span style="width:8px;height:8px;border-radius:50%;background:#ef4444;display:inline-block"></span>Active threats · <span id="map-threat-count">4</span></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Grid du bas : Chart, Donut, Top sources -->
  <div class="soc-grid-bottom">

    <!-- Bar chart -->
    <div class="panel">
      <div class="panel-head">
        <div class="panel-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          Events / Heure (24h)
        </div>
        <div class="panel-tools"><span class="panel-tool active">24h</span><span class="panel-tool">7j</span><span class="panel-tool">30j</span></div>
      </div>
      <div class="panel-body">
        <div class="chart-wrap">
          <div class="chart-bars" id="chart-bars"></div>
        </div>
      </div>
    </div>

    <!-- Threat donut -->
    <div class="panel">
      <div class="panel-head">
        <div class="panel-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2 A10 10 0 0 1 22 12 L12 12 Z" fill="currentColor"/></svg>
          Threat Types
        </div>
      </div>
      <div class="panel-body">
        <div class="donut-wrap">
          <div class="donut">
            <svg width="130" height="130" viewBox="0 0 130 130">
              <circle cx="65" cy="65" r="48" fill="none" stroke="#1e293b" stroke-width="18"/>
              <!-- 4 segments: DDoS 40%, SQLi 25%, XSS 20%, Brute 15% -->
              <circle cx="65" cy="65" r="48" fill="none" stroke="#ef4444" stroke-width="18"
                      stroke-dasharray="120.6 301.6" stroke-dashoffset="0"/>
              <circle cx="65" cy="65" r="48" fill="none" stroke="#f59e0b" stroke-width="18"
                      stroke-dasharray="75.4 301.6" stroke-dashoffset="-120.6"/>
              <circle cx="65" cy="65" r="48" fill="none" stroke="#3b82f6" stroke-width="18"
                      stroke-dasharray="60.3 301.6" stroke-dashoffset="-196"/>
              <circle cx="65" cy="65" r="48" fill="none" stroke="#8b5cf6" stroke-width="18"
                      stroke-dasharray="45.2 301.6" stroke-dashoffset="-256.3"/>
            </svg>
            <div class="donut-center">
              <div class="num">12.8k</div>
              <div class="lbl">Total</div>
            </div>
          </div>
          <div class="donut-legend">
            <div class="donut-leg-item"><span class="sw" style="background:#ef4444"></span>DDoS<span class="v">40%</span></div>
            <div class="donut-leg-item"><span class="sw" style="background:#f59e0b"></span>SQLi<span class="v">25%</span></div>
            <div class="donut-leg-item"><span class="sw" style="background:#3b82f6"></span>XSS<span class="v">20%</span></div>
            <div class="donut-leg-item"><span class="sw" style="background:#8b5cf6"></span>Brute-force<span class="v">15%</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Top sources -->
    <div class="panel">
      <div class="panel-head">
        <div class="panel-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" y1="8" x2="12" y2="8"/><line x1="3.95" y1="6.06" x2="8.54" y2="14"/><line x1="10.88" y1="21.94" x2="15.46" y2="14"/></svg>
          Top Source IPs
        </div>
      </div>
      <div class="panel-body">
        <div class="src-list">
          <div class="src-row">
            <div><div class="src-ip">185.220.101.42</div><div class="src-country">🇷🇺 RU · TOR exit</div></div>
            <div class="src-count">1,847</div>
            <button class="panel-tool" style="font-size:0.65rem">BLOCK</button>
          </div>
          <div class="src-row">
            <div><div class="src-ip">91.234.18.55</div><div class="src-country">🇨🇳 CN · Beijing</div></div>
            <div class="src-count">1,204</div>
            <button class="panel-tool" style="font-size:0.65rem">BLOCK</button>
          </div>
          <div class="src-row">
            <div><div class="src-ip">45.142.214.219</div><div class="src-country">🇰🇵 KP · Pyongyang</div></div>
            <div class="src-count">983</div>
            <button class="panel-tool" style="font-size:0.65rem">BLOCK</button>
          </div>
          <div class="src-row">
            <div><div class="src-ip">194.180.49.114</div><div class="src-country">🇮🇷 IR · Tehran</div></div>
            <div class="src-count">812</div>
            <button class="panel-tool" style="font-size:0.65rem">BLOCK</button>
          </div>
          <div class="src-row">
            <div><div class="src-ip">103.224.182.245</div><div class="src-country">🇻🇳 VN · Hanoi</div></div>
            <div class="src-count">654</div>
            <button class="panel-tool" style="font-size:0.65rem">BLOCK</button>
          </div>
          <div class="src-row">
            <div><div class="src-ip">5.188.10.180</div><div class="src-country">🇷🇺 RU · St-Petersburg</div></div>
            <div class="src-count">521</div>
            <button class="panel-tool" style="font-size:0.65rem">BLOCK</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Active alerts -->
  <div class="panel" style="margin-top:var(--sp-4)">
    <div class="panel-head">
      <div class="panel-title">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Active Alerts
        <span class="live-tag">3 CRITICAL</span>
      </div>
      <div class="panel-tools"><span class="panel-tool">View all →</span></div>
    </div>
    <div class="panel-body">
      <div class="alert-list">
        <div class="alert-row">
          <span class="alert-dot crit"></span>
          <div class="alert-body">
            <div class="alert-title">SQL injection attempt on <code style="color:var(--accent-2)">/api/users</code> from 185.220.101.42</div>
            <div class="alert-meta">WAF rule #1042 triggered · Blocked · GeoIP: RU · ASN: AS9009</div>
          </div>
          <div class="alert-time">il y a 12s</div>
        </div>
        <div class="alert-row">
          <span class="alert-dot crit"></span>
          <div class="alert-body">
            <div class="alert-title">DDoS volumetric attack — 48k req/s</div>
            <div class="alert-meta">Mitigated at edge · Anycast network · Layer 7</div>
          </div>
          <div class="alert-time">il y a 1m</div>
        </div>
        <div class="alert-row">
          <span class="alert-dot warn"></span>
          <div class="alert-body">
            <div class="alert-title">Brute-force credentials detected on <code style="color:var(--accent-2)">/admin/login</code></div>
            <div class="alert-meta">Rate-limit activé · 23 IPs bannies sur 5 min</div>
          </div>
          <div class="alert-time">il y a 3m</div>
        </div>
        <div class="alert-row">
          <span class="alert-dot info"></span>
          <div class="alert-body">
            <div class="alert-title">TLS certificate auto-renewed (Let's Encrypt)</div>
            <div class="alert-meta">Valid jusqu'au 24 août 2026 · DNS-01 challenge passed</div>
          </div>
          <div class="alert-time">il y a 12m</div>
        </div>
        <div class="alert-row">
          <span class="alert-dot info"></span>
          <div class="alert-body">
            <div class="alert-title">Patch de sécurité appliqué — openssl 3.0.13 → 3.0.14</div>
            <div class="alert-meta">Auto-deploy · 0 downtime · Vérification post-deploy OK</div>
          </div>
          <div class="alert-time">il y a 1h</div>
        </div>
      </div>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
