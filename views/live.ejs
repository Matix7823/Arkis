<!-- Keyframe animation for pulse glow in the style scope -->
<style>
@keyframes pulseGlow {
  0% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.3); opacity: 1; box-shadow: 0 0 10px var(--clr-green); }
  100% { transform: scale(1); opacity: 0.8; }
}
.live-site-item:hover {
  border-color: rgba(0, 212, 255, 0.25) !important;
}
.reassure-card:hover {
  border-color: rgba(123, 47, 255, 0.25) !important;
}
</style>

