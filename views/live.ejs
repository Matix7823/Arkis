<script>
/* ═══════════════════════════════════════════════════════════
   ARKIS SOC DASHBOARD — Live SIEM Engine
   Self-contained script for the Live SOC page
═══════════════════════════════════════════════════════════ */

// ── State ──────────────────────────────────────────────────
const state = {
  events: [],
  filteredEvents: [],
  activeFilter: 'all',
  counters: {
    blocked: 0,
    blocked_rate: 0,
    rps: 0,
    total_events: 0,
    warn_count: 0,
  },
  chartData: Array(60).fill(0),
  isAttacking: false,
  attackType: null,
  cpu: 18, ram: 34, bw: 2.4, lat: 8,
};

const clients = ['DHM-Tech', 'Bricosam.fr', "L'Écrin Sucré", 'Salon Signature', 'SOC Industriel', 'Arkis Agency'];
const ipPool = () => {
  const r = () => Math.floor(Math.random() * 254) + 1;
  return `${r()}.${r()}.${r()}.${r()}`;
};

// ── SIEM Log Definitions ───────────────────────────────────
const LOG_TEMPLATES = {
  sqli: () => ({
    level: 'BLOCKED', type: 'SQLi',
    msg: `SQL Injection detected on endpoint /${['search','api/users','products','checkout'][Math.floor(Math.random()*4)]} → Dropped by Cloudflare WAF (OWASP CRS Rule 942100). Source: ${ipPool()}`
  }),
  xss: () => ({
    level: 'BLOCKED', type: 'XSS',
    msg: `Cross-Site Scripting payload blocked on ${['/contact','/comment','/api/v2/data'][Math.floor(Math.random()*3)]} — Script injection sanitized. Source: ${ipPool()}`
  }),
  ddos: () => ({
    level: 'BLOCKED', type: 'DDoS',
    msg: `Layer-7 HTTP flood mitigated — ${(300+Math.floor(Math.random()*400)).toLocaleString()} req/s absorbed by Edge CDG. BGP Anycast rerouting engaged.`
  }),
  bruteforce: () => ({
    level: 'BLOCKED', type: 'BruteForce',
    msg: `Credential stuffing detected on /admin — Rate-limit 429 engaged after ${5+Math.floor(Math.random()*10)} failed attempts. Source: ${ipPool()}`
  }),
  bot: () => ({
    level: 'BLOCKED', type: 'Bot',
    msg: `Malicious crawler fingerprint detected — User-Agent: "${['SentryBot/1.0','Scrapy/2.6','masscan/1.3','nmap/7.9'][Math.floor(Math.random()*4)]}" → Blocked at Edge. Source: ${ipPool()}`
  }),
  tls: () => ({
    level: 'INFO', type: 'TLS',
    msg: `TLS 1.3 handshake verified — ECDHE_RSA_AES256_GCM_SHA384 on ${clients[Math.floor(Math.random()*clients.length)]}. HSTS enforced.`
  }),
  cache: () => ({
    level: 'INFO', type: 'Cache',
    msg: `Static page delivery from Edge cache (Cloudflare POP CDG) — Cache HIT ratio: ${(85+Math.floor(Math.random()*15))}%. Asset: ${clients[Math.floor(Math.random()*clients.length)]}`
  }),
  rls: () => ({
    level: 'INFO', type: 'RLS',
    msg: `Row-Level Security policy enforced — Supabase isolation confirmed. User scope restricted to tenant ID #${Math.floor(Math.random()*9999)+1000}`
  }),
  zerotrust: () => ({
    level: 'INFO', type: 'ZeroTrust',
    msg: `Zero-Trust token validated — mTLS certificate presented. Identity: service-account@${clients[Math.floor(Math.random()*clients.length)].toLowerCase().replace(/\s/g,'-')}`
  }),
  integrity: () => ({
    level: 'INFO', type: 'Integrity',
    msg: `SHA-256 asset hash verified — Edge static manifest integrity check PASS on ${clients[Math.floor(Math.random()*clients.length)]}`
  }),
  cve: () => ({
    level: 'WARN', type: 'CVE',
    msg: `CVE Advisory: ${['CVE-2025-0132','CVE-2025-1841','CVE-2024-9956','CVE-2025-0330'][Math.floor(Math.random()*4)]} — Patch status: RESOLVED. Client stacks auto-updated.`
  }),
  ratelimit: () => ({
    level: 'WARN', type: 'RateLimit',
    msg: `Threshold exceeded — ${Math.floor(Math.random()*200)+50} req/5s from ${ipPool()} on /${['api','login','checkout','search'][Math.floor(Math.random()*4)]}. HTTP 429 returned.`
  }),
  pentest: () => ({
    level: 'INFO', type: 'PenTest',
    msg: `Scheduled pen-test routine — OWASP ZAP scan completed on ${clients[Math.floor(Math.random()*clients.length)]}. CVE found: 0. Score: A+`
  }),
};

const NORMAL_POOL = ['tls','cache','rls','zerotrust','integrity','pentest'];
const THREAT_POOL = ['sqli','xss','bot','ratelimit'];
const CRITICAL_POOL = ['ddos','bruteforce','cve'];

function getRandomLog() {
  const roll = Math.random();
  let pool;
  if (state.isAttacking) {
    if (state.attackType === 'ddos') pool = ['ddos','ratelimit','bot'];
    else if (state.attackType === 'sqli') pool = ['sqli','sqli','xss'];
    else if (state.attackType === 'xss') pool = ['xss','xss','sqli'];
    else pool = ['bruteforce','bruteforce','ratelimit'];
  } else {
    if (roll < 0.55) pool = NORMAL_POOL;
    else if (roll < 0.85) pool = THREAT_POOL;
    else pool = CRITICAL_POOL;
  }
  const key = pool[Math.floor(Math.random()*pool.length)];
  return { key, ...LOG_TEMPLATES[key]() };
}

// ── Console Renderer ───────────────────────────────────────
const consoleEl = document.getElementById('soc-console');
const MAX_EVENTS = 200;

function addLog(log) {
  const now = new Date();
  const ts = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}:${String(now.getSeconds()).padStart(2,'0')}`;

  const entry = {
    ts,
    level: log.level,
    type: log.type,
    msg: log.msg,
    id: Date.now() + Math.random()
  };

  state.events.unshift(entry);
  if (state.events.length > MAX_EVENTS) state.events.pop();

  // Counters
  state.counters.total_events++;
  if (log.level === 'BLOCKED') {
    state.counters.blocked++;
    state.counters.blocked_rate = Math.min(state.counters.blocked_rate + 1, 999);
  }
  if (log.level === 'WARN') state.counters.warn_count++;

  renderConsole();
  updateCounters();
}

function renderConsole() {
  const filter = state.activeFilter;
  const visible = filter === 'all'
    ? state.events
    : state.events.filter(e => e.level === filter);

  // Rebuild only if needed (perf)
  const html = visible.slice(0, 80).map(e => {
    const cls = e.level === 'BLOCKED' ? 'soc-log-blocked'
              : e.level === 'WARN'    ? 'soc-log-warn'
              : 'soc-log-info';
    const badge = e.level === 'BLOCKED' ? `<span class="soc-log-badge soc-lb-red">${e.level}</span>`
                : e.level === 'WARN'    ? `<span class="soc-log-badge soc-lb-yellow">${e.level}</span>`
                : `<span class="soc-log-badge soc-lb-blue">${e.level}</span>`;
    return `<div class="soc-log-entry ${cls}">
      <span class="soc-log-ts font-mono">${e.ts}</span>
      ${badge}
      <span class="soc-log-type font-mono">[${e.type}]</span>
      <span class="soc-log-msg">${e.msg}</span>
    </div>`;
  }).join('');

  consoleEl.innerHTML = html;
}

function updateCounters() {
  const el = (id, val) => { const e = document.getElementById(id); if(e) e.textContent = val; };
  el('kpi-blocked', state.counters.blocked.toLocaleString());
  el('kpi-blocked-rate', state.counters.blocked_rate);
  el('event-count', state.counters.total_events.toLocaleString());
  el('event-blocked', state.events.filter(e=>e.level==='BLOCKED').length);
  el('event-warn', state.events.filter(e=>e.level==='WARN').length);
}

// ── Clock ──────────────────────────────────────────────────
function updateClock() {
  const now = new Date();
  const utc = `${String(now.getUTCHours()).padStart(2,'0')}:${String(now.getUTCMinutes()).padStart(2,'0')}:${String(now.getUTCSeconds()).padStart(2,'0')} UTC`;
  const el = document.getElementById('soc-clock');
  if (el) el.textContent = utc;
}
setInterval(updateClock, 1000);
updateClock();

// ── Traffic Chart ──────────────────────────────────────────
const canvas = document.getElementById('soc-traffic-chart');
const ctx = canvas ? canvas.getContext('2d') : null;

function drawChart() {
  if (!ctx) return;
  const W = canvas.offsetWidth;
  const H = canvas.offsetHeight || 120;
  canvas.width = W;
  canvas.height = H;

  const max = Math.max(...state.chartData, 100);
  const step = W / (state.chartData.length - 1);

  ctx.clearRect(0, 0, W, H);

  // Grid lines
  ctx.strokeStyle = 'rgba(0,212,255,0.06)';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = (H / 4) * i;
    ctx.beginPath();
    ctx.moveTo(0, y);
    ctx.lineTo(W, y);
    ctx.stroke();
  }

  // Gradient fill
  const grad = ctx.createLinearGradient(0, 0, 0, H);
  grad.addColorStop(0, 'rgba(0, 212, 255, 0.3)');
  grad.addColorStop(1, 'rgba(0, 212, 255, 0.0)');

  ctx.beginPath();
  state.chartData.forEach((val, i) => {
    const x = i * step;
    const y = H - (val / max) * (H - 8) - 4;
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.lineTo((state.chartData.length - 1) * step, H);
  ctx.lineTo(0, H);
  ctx.closePath();
  ctx.fillStyle = grad;
  ctx.fill();

  // Line
  ctx.beginPath();
  ctx.strokeStyle = '#00D4FF';
  ctx.lineWidth = 2;
  ctx.shadowBlur = 8;
  ctx.shadowColor = '#00D4FF';
  state.chartData.forEach((val, i) => {
    const x = i * step;
    const y = H - (val / max) * (H - 8) - 4;
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.stroke();
  ctx.shadowBlur = 0;

  // Peak label
  const peak = document.getElementById('chart-peak');
  if (peak) peak.textContent = `Peak: ${max.toLocaleString()} req/s`;
}

// ── System Metrics ─────────────────────────────────────────
function updateSysMetrics() {
  const targetCpu = state.isAttacking
    ? 80 + Math.floor(Math.random()*18)
    : 12 + Math.floor(Math.random()*22);

  state.cpu += (targetCpu - state.cpu) * 0.15;
  state.ram = 28 + Math.sin(Date.now()/10000)*8 + Math.random()*5;
  state.bw = state.isAttacking ? 8 + Math.random()*12 : 1.8 + Math.random()*2;
  state.lat = state.isAttacking ? 25 + Math.random()*40 : 6 + Math.random()*8;

  const setBar = (barId, valId, pct, val) => {
    const b = document.getElementById(barId); const v = document.getElementById(valId);
    if(b) b.style.width = `${Math.min(pct,100)}%`;
    if(v) v.textContent = val;
    if(b) {
      b.style.background = pct > 80 ? 'var(--clr-red)' : pct > 60 ? '#FBBF24' : '';
    }
  };

  setBar('cpu-bar','cpu-val', state.cpu, `${Math.round(state.cpu)}%`);
  setBar('ram-bar','ram-val', state.ram, `${Math.round(state.ram)}%`);
  setBar('bw-bar','bw-val', (state.bw/20)*100, `${state.bw.toFixed(1)} Gbps`);
  setBar('lat-bar','lat-val', (state.lat/100)*100, `${Math.round(state.lat)}ms`);

  // RPS
  const rps = state.isAttacking ? 800+Math.floor(Math.random()*400) : 80+Math.floor(Math.random()*120);
  const kpiRps = document.getElementById('kpi-rps');
  if (kpiRps) kpiRps.textContent = rps.toLocaleString();
  state.chartData.push(rps);
  state.chartData.shift();
  drawChart();
}

// ── Threat Distribution ────────────────────────────────────
function updateThreatDist() {
  const dist = state.isAttacking ? { ddos: 65, sqli: 15, xss: 10, bot: 6, bf: 4 }
                                 : { ddos: 38, sqli: 22, xss: 18, bot: 14, bf: 8 };

  const keys = ['ddos','sqli','xss','bot','bf'];
  keys.forEach(k => {
    const bar = document.getElementById(`bar-${k}`);
    const pct = document.getElementById(`pct-${k}`);
    if (bar) bar.style.width = `${dist[k]}%`;
    if (pct) pct.textContent = `${dist[k]}%`;
  });
}

