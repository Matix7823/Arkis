  { country: 'CN', ip: '218.92.0.0/16', threat: 'APT41 Botnet', severity: 'CRITICAL' },
  { country: 'RU', ip: '91.234.18.55', threat: 'Emotet C2 Node', severity: 'HIGH' },
  { country: 'KP', ip: '175.45.176.0/22', threat: 'Lazarus Group', severity: 'CRITICAL' },
  { country: 'BR', ip: '189.40.0.0/14', threat: 'Credential Stuffing Ring', severity: 'MEDIUM' },
  { country: 'US', ip: '104.21.48.1', threat: 'Tor Exit Node', severity: 'LOW' },
  { country: 'DE', ip: '46.243.189.0/24', threat: 'DDoS-for-Hire', severity: 'HIGH' },
];

function renderThreatFeed() {
  const feed = document.getElementById('threat-feed');
  if (!feed) return;
  feed.innerHTML = THREAT_INTEL.map(t => `
    <div class="soc-threat-item">
      <div class="soc-threat-flag">${t.country}</div>
      <div class="soc-threat-details">
        <span class="soc-threat-ip font-mono">${t.ip}</span>
        <span class="soc-threat-name">${t.threat}</span>
      </div>
      <span class="soc-threat-sev soc-sev-${t.severity.toLowerCase()}">${t.severity}</span>
    </div>
  `).join('');
}

// ── Attack Simulator ───────────────────────────────────────
function initAttacks() {
  const attacks = [
    { id: 'btn-ddos', type: 'ddos', name: 'DDoS Flood' },
    { id: 'btn-sqli', type: 'sqli', name: 'SQL Injection' },
    { id: 'btn-xss',  type: 'xss',  name: 'XSS Payload' },
    { id: 'btn-bruteforce', type: 'bruteforce', name: 'Brute Force' },
  ];

  attacks.forEach(atk => {
    const btn = document.getElementById(atk.id);
    if (!btn) return;
    btn.addEventListener('click', () => {
      if (state.isAttacking) return;
      state.isAttacking = true;
      state.attackType = atk.type;

      btn.classList.add('soc-atk-active');
      document.querySelectorAll('.soc-atk-btn').forEach(b => b.disabled = true);

      const statusEl = document.getElementById('attack-status');
      if (statusEl) {
        statusEl.innerHTML = `<span style="color:#EF4444;animation:blink 0.5s infinite;">⚠</span> ATTACK ENGAGED: ${atk.name.toUpperCase()} — WAF mitigation active...`;
      }

      // Inject rapid attack logs
      let count = 0;
      const atk_interval = setInterval(() => {
        addLog(getRandomLog());
        count++;
        if (count >= 20) {
          clearInterval(atk_interval);
          state.isAttacking = false;
          state.attackType = null;
          btn.classList.remove('soc-atk-active');
          document.querySelectorAll('.soc-atk-btn').forEach(b => b.disabled = false);
          if (statusEl) {
            statusEl.innerHTML = `<span style="color:var(--clr-green);">◉</span> MITIGATION COMPLETE — ${atk.name} attack neutralized. 0 data breached.`;
          }
        }
      }, 200);
    });
  });
}

// ── Filter Tabs ────────────────────────────────────────────
document.querySelectorAll('.soc-filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.soc-filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    state.activeFilter = btn.dataset.filter;
    renderConsole();
  });
});

// Clear button
const clearBtn = document.getElementById('soc-clear-btn');
if (clearBtn) clearBtn.addEventListener('click', () => {
  state.events = [];
  state.counters = { blocked: 0, blocked_rate: 0, rps: 0, total_events: 0, warn_count: 0 };
  renderConsole();
  updateCounters();
});

// ── Main Loop ──────────────────────────────────────────────
function mainLoop() {
  // Inject new event
  addLog(getRandomLog());
  updateSysMetrics();
  updateThreatDist();
}

// ── Init ───────────────────────────────────────────────────
renderThreatFeed();
initAttacks();

// Initial events burst
for (let i = 0; i < 12; i++) {
  setTimeout(() => addLog(getRandomLog()), i * 100);
}

// Recurring intervals
setInterval(mainLoop, state.isAttacking ? 400 : 1800);
setInterval(() => {
  // Variable speed
  const delay = 800 + Math.random() * 2000;
  setTimeout(mainLoop, delay);
}, 2500);

</script>
</main>
