  <!-- ═══════════════════════════════════════════════
       INTERACTIVE CYBER ROI & BUDGET SIMULATOR
       ═══════════════════════════════════════════════ -->
  <section id="calculator" class="section simulator-section" style="background: var(--clr-bg); border-top: 1px solid var(--clr-border); padding: 5rem 0; position: relative; overflow: hidden;">
    <div style="position: absolute; inset: 0; background: radial-gradient(circle at 80% 20%, rgba(0, 212, 255, 0.04), transparent 50%); pointer-events: none;" aria-hidden="true"></div>
    
    <div class="container">
      <div class="section-header" style="text-align: center; margin-bottom: 4rem;">
        <p class="section-tag reveal-up">Simulateur Interactif</p>
        <h2 class="section-title reveal-up delay-1">Estimez votre <span class="gradient-text">Projet Sur-Mesure.</span></h2>
        <p class="section-subtitle reveal-up delay-2" style="margin-inline: auto;">Configurez votre infrastructure, ajustez le niveau de blindage WAF et de support pour calculer votre devis estimatif en direct.</p>
      </div>

      <div class="simulator-layout" style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 3rem; align-items: start;">
        
        <!-- Controls Panel -->
        <div class="simulator-controls reveal-up delay-1" style="background: var(--clr-bg-card); border: 1px solid var(--clr-border); border-radius: var(--radius-lg); padding: 2.5rem; display: flex; flex-direction: column; gap: 2rem; box-shadow: var(--shadow-card);">
          
          <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--clr-text); border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-cyan)" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/></svg>
            Configuration de la Stack
          </h3>

          <!-- Control 1: Pages Slider -->
          <div class="control-group">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
              <label for="sim-pages" style="font-weight: 600; font-size: 0.95rem; color: var(--clr-text);">Volume de Pages</label>
              <span class="font-mono" style="font-size: 0.85rem; color: var(--clr-cyan); background: var(--clr-cyan-dim); padding: 0.2rem 0.6rem; border-radius: 6px;" id="sim-pages-val">5 pages</span>
            </div>
            <input type="range" id="sim-pages" min="1" max="30" value="5" style="width: 100%; height: 6px; border-radius: 3px; background: rgba(255,255,255,0.08); outline: none; transition: background 0.3s; cursor: pointer; -webkit-appearance: none;" />
            <p style="font-size: 0.75rem; color: var(--clr-text-3); margin-top: 0.5rem;">Idéal pour les sites vitrines à fort impact (150 € par page supplémentaire au-delà de 5).</p>
          </div>

          <!-- Control 2: Database Checkbox -->
          <div class="control-group" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); border-radius: var(--radius-md); padding: 1.25rem; transition: border-color var(--t-fast);">
            <label class="checkbox-wrap" style="display: flex; gap: 1rem; align-items: flex-start; cursor: pointer;">
              <input type="checkbox" id="sim-db" style="width: 20px; height: 20px; accent-color: var(--clr-cyan); cursor: pointer;" />
              <div>
                <span style="font-weight: 600; font-size: 0.95rem; color: var(--clr-text); display: block; margin-bottom: 0.25rem;">Base de Données Supabase (PostgreSQL)</span>
                <span style="font-size: 0.78rem; color: var(--clr-text-2); display: block; line-height: 1.4;">Active le temps réel, l'isolation Row-Level Security (RLS) et l'accès sécurisé à des fonctionnalités dynamiques.</span>
              </div>
            </label>
          </div>

          <!-- Control 3: Cloudflare Security Dropdown -->
          <div class="control-group">
            <label for="sim-security" style="font-weight: 600; font-size: 0.95rem; color: var(--clr-text); display: block; margin-bottom: 0.75rem;">Bouclier de Sécurité Cloudflare</label>
            <select id="sim-security" style="width: 100%; padding: 0.85rem 1.25rem; background: var(--clr-bg-2); border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: var(--clr-text); font-weight: 500; font-size: 0.9rem; cursor: pointer; outline: none; transition: border-color 0.2s;">
              <option value="basic">Standard Edge CDN (Hébergement de base)</option>
              <option value="advanced" selected>Advanced WAF & DDoS Shield (Hautement recommandé)</option>
              <option value="enterprise">Zero-Trust Enterprise Vault (Blindage maximal)</option>
            </select>
            <p style="font-size: 0.75rem; color: var(--clr-text-3); margin-top: 0.5rem;">Détermine la couche de filtration des menaces en direct à la périphérie du réseau (Edge).</p>
          </div>

          <!-- Control 4: RUN Support Dropdown -->
          <div class="control-group">
            <label for="sim-support" style="font-weight: 600; font-size: 0.95rem; color: var(--clr-text); display: block; margin-bottom: 0.75rem;">Maintenance & Support RUN</label>
            <select id="sim-support" style="width: 100%; padding: 0.85rem 1.25rem; background: var(--clr-bg-2); border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: var(--clr-text); font-weight: 500; font-size: 0.9rem; cursor: pointer; outline: none; transition: border-color 0.2s;">
              <option value="none">Aucun abonnement (Hébergement statique brut)</option>
              <option value="essentiel">Run Essentiel (Sauvegardes & Mises à jour — 149 €/m)</option>
              <option value="business" selected>Run Business (Support 24/7 & WAF actif — 349 €/m)</option>
              <option value="critique">Run Critique (SLA 99.99% & Astreinte CTO — 890 €/m)</option>
            </select>
            <p style="font-size: 0.75rem; color: var(--clr-text-3); margin-top: 0.5rem;">Support réactif d'ingénieurs seniors en direct sur Slack pour toute urgence de cybersécurité.</p>
          </div>

        </div>

        <!-- Dynamic Results Card -->
        <div class="simulator-results reveal-up delay-2" style="position: sticky; top: calc(var(--nav-h) + 2rem); display: flex; flex-direction: column; gap: 1.5rem;">
          
          <!-- Price Box -->
          <div style="background: linear-gradient(160deg, #0D1630 0%, #0A1225 100%); border: 1px solid rgba(0, 212, 255, 0.25); border-radius: var(--radius-lg); padding: 2.5rem; box-shadow: var(--shadow-glow-c); position: relative; overflow: hidden;">
            <div style="position: absolute; top: -1px; right: 2rem; background: var(--grad-primary); color: #fff; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; padding: 0.25rem 0.8rem; border-radius: 0 0 6px 6px;">Estimation Devis</div>
            
            <h4 style="font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; color: var(--clr-text-3); letter-spacing: 0.05em; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
              <span style="display:inline-block; width:6px; height:6px; background:var(--clr-cyan); border-radius:50%;"></span>
              Montant Estimatif du Devis
            </h4>

            <div style="display: flex; flex-direction: column; gap: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1.75rem; margin-bottom: 1.75rem;">
              
              <!-- Build cost -->
              <div>
                <span style="font-size: 0.85rem; color: var(--clr-text-2); display: block; margin-bottom: 0.25rem;">PHASE 1 — BUILD (Coût de création unique)</span>
                <div style="display: flex; align-items: baseline; gap: 0.35rem;">
                  <span class="font-mono" style="font-size: 2.25rem; font-weight: 800; color: var(--clr-text);" id="sim-build-price">2 900</span>
                  <span style="font-size: 1.25rem; color: var(--clr-text-2); font-weight: 600;">€</span>
                  <span style="font-size: 0.78rem; color: var(--clr-text-3); font-family: var(--font-mono); margin-left: 0.5rem;">one-time build</span>
                </div>
              </div>

              <!-- Run cost -->
              <div>
                <span style="font-size: 0.85rem; color: var(--clr-text-2); display: block; margin-bottom: 0.25rem;">PHASE 2 — RUN (Hébergement & Cybersécurité mensuels)</span>
                <div style="display: flex; align-items: baseline; gap: 0.35rem;">
                  <span class="font-mono" style="font-size: 2.25rem; font-weight: 800; color: var(--clr-cyan);" id="sim-run-price">349</span>
                  <span style="font-size: 1.25rem; color: var(--clr-cyan); font-weight: 600;">€</span>
                  <span style="font-size: 0.78rem; color: var(--clr-text-3); font-family: var(--font-mono); margin-left: 0.5rem;">/ mois</span>
                </div>
              </div>

            </div>

            <!-- Dynamic ROI and Cyber indicators inside the card -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem;">
              
              <!-- Speed/LCP Performance score -->
              <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); border-radius: var(--radius-md); padding: 0.85rem; text-align: center;">
                <span style="font-size: 0.65rem; color: var(--clr-text-3); font-family: var(--font-mono); text-transform: uppercase; display: block; margin-bottom: 0.25rem;">Score LCP Estimé</span>
                <strong class="font-mono" style="font-size: 1.25rem; color: var(--clr-green);" id="sim-lcp-val">100 / 100</strong>
              </div>

              <!-- Security rating -->
              <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); border-radius: var(--radius-md); padding: 0.85rem; text-align: center;">
                <span style="font-size: 0.65rem; color: var(--clr-text-3); font-family: var(--font-mono); text-transform: uppercase; display: block; margin-bottom: 0.25rem;">Niveau de Sécurité</span>
                <strong class="font-mono" style="font-size: 1.25rem; color: var(--clr-cyan);" id="sim-security-val">Grade A</strong>
              </div>

            </div>

            <!-- Dispatch CTA button -->
            <a href="/contact" class="btn btn-primary btn-full" id="sim-quote-btn" style="justify-content: center; font-size: 0.95rem; font-weight: 700;">
              Transmettre ce devis
              <span aria-hidden="true" style="margin-left: 0.5rem;">→</span>
            </a>

          </div>

          <!-- Small disclaimer -->
          <div style="font-size: 0.75rem; color: var(--clr-text-3); line-height: 1.5; padding: 0 1rem; text-align: center;">
            * Cette simulation est fournie à titre indicatif. Un ingénieur Arkis analysera vos spécifications techniques pour valider le cahier des charges et émettre le contrat final.
          </div>

        </div>

      </div>

    </div>
  </section>
</main>

<style>
/* Slider styling tweaks */
input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--clr-cyan);
  box-shadow: 0 0 10px var(--clr-cyan-glow);
  cursor: pointer;
  transition: transform 0.1s;
}
input[type="range"]::-webkit-slider-thumb:hover {
  transform: scale(1.2);
}
@media (max-width: 992px) {
  .simulator-layout {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
}
</style>

