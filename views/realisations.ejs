            </div>
          </div>
        </article>

        <!-- Project 5: Salon Signature -->
        <article class="portfolio-card reveal-up delay-2" data-category="vitrine" id="project-hair">
          <div class="portfolio-img-wrap">
            <img src="images/portfolio_mockup2.png" alt="Salon Signature Coiffure site web chic" loading="lazy" />
            <div class="portfolio-overlay">
              <div class="portfolio-tags">
                <span class="p-tag">React Calendar</span>
                <span class="p-tag">Supabase Auth</span>
                <span class="p-tag">Encrypted Booking</span>
              </div>
            </div>
          </div>
          <div class="portfolio-info">
            <div class="portfolio-meta">
