        <!-- Project 4: L'Écrin Sucré -->
        <article class="portfolio-card reveal-up delay-1" data-category="vitrine" id="project-bakery">
          <div class="portfolio-img-wrap">
            <img src="images/portfolio_commerce.png" alt="Boulangerie L'Écrin Sucré site web moderne" loading="lazy" />
            <div class="portfolio-overlay">
              <div class="portfolio-tags">
