        </div>
        <div class="portfolio-stat-item">
          <span class="portfolio-stat-value">0</span>
          <span class="portfolio-stat-label">CVE critique livré</span>
        </div>
        <div class="portfolio-stat-item">
          <span class="portfolio-stat-value">2.4M</span>
          <span class="portfolio-stat-label">Menaces bloquées</span>
        </div>
        <div class="portfolio-stat-item">
          <span class="portfolio-stat-value">99.99%</span>
          <span class="portfolio-stat-label">Uptime global</span>
        </div>
      </div>
    </div>
  </section>

