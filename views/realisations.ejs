<%- include('partials/head', {
  title: 'Maquettes & Réalisations — Arkis',
  description: 'Découvrez nos maquettes et projets livrés : sites vitrines, e-commerce, dashboards SaaS, plateformes métier. Tous sécurisés par défaut.'
}) %>

<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <span class="eyebrow">Maquettes &amp; Réalisations</span>
    <h1>Quelques projets livrés récemment</h1>
    <p>Chaque site est conçu sur-mesure, optimisé pour la performance et sécurisé dès la conception. Cliquez pour visualiser la démo live.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="mockups-grid">
      <%
        const projects = [
          {
            img: '/images/portfolio_bricosam.png',
            url: 'bricosam.fr',
            name: 'BricoSam',
            desc: 'Site vitrine pour un artisan bricoleur : prise de RDV, galerie de réalisations, devis en ligne.',
            tags: ['Next.js', 'Tailwind', 'Sanity CMS', 'Cloudflare'],
            category: 'Vitrine',
            metrics: { perf: '99', sec: 'A+' }
          },
          {
            img: '/images/portfolio_commerce.png',
            url: 'shop.dhmtech.fr',
            name: 'DHM Shop',
            desc: 'E-commerce B2B électronique : 4000+ produits, paiement Stripe, gestion stocks temps réel, espace pro.',
            tags: ['Astro', 'Stripe', 'PostgreSQL', 'Algolia'],
            category: 'E-commerce',
            metrics: { perf: '96', sec: 'A+' }
          },
          {
            img: '/images/portfolio_dhmtech.png',
            url: 'dhmtech.fr',
            name: 'DHM Tech',
            desc: 'Plateforme SaaS de gestion d\'interventions techniques : tickets, planning, app mobile, API REST.',
            tags: ['Next.js', 'Supabase', 'Auth', 'WebSockets'],
            category: 'SaaS',
            metrics: { perf: '94', sec: 'A+' }
          },
          {
            img: '/images/portfolio_mockup1.png',
            url: 'studio-lumen.example',
            name: 'Studio Lumen',
            desc: 'Portfolio photographique haut-de-gamme : galeries lightbox, espace client privé, blog SEO.',
            tags: ['Astro', 'Tailwind', 'Imagekit'],
            category: 'Portfolio',
            metrics: { perf: '100', sec: 'A+' }
          }
        ];
        projects.forEach(p => {
      %>
        <article class="mockup reveal">
          <div class="mockup-img">
            <div class="browser-bar"><span></span><span></span><span></span><div class="url"><%= p.url %></div></div>
            <img src="<%= p.img %>" alt="Maquette <%= p.name %>" loading="lazy"
                 onerror="this.parentNode.insertAdjacentHTML('beforeend','<div class=\'mockup-placeholder\'><div class=\'pl-header\'><div class=\'pl-logo\'></div><div class=\'pl-link\'></div><div class=\'pl-link\'></div><div class=\'pl-link\'></div></div><div class=\'pl-hero\'><div class=\'pl-hero-text\'><div class=\'pl-h\'></div><div class=\'pl-h s\'></div><div class=\'pl-p\'></div><div class=\'pl-p\'></div><div class=\'pl-btn\'></div></div><div class=\'pl-img\'></div></div><div class=\'pl-grid\'><div></div><div></div><div></div></div></div>'); this.remove();" />
          </div>
          <div class="mockup-body">
            <div class="mockup-tags">
              <span class="mockup-tag" style="background:#eef2ff;color:var(--brand-1);border-color:#e0e7ff"><%= p.category %></span>
              <% p.tags.forEach(t => { %><span class="mockup-tag"><%= t %></span><% }) %>
            </div>
            <h3><%= p.name %></h3>
            <p><%= p.desc %></p>
            <div style="display:flex;gap:var(--sp-4);margin-bottom:var(--sp-4);font-size:0.8125rem;color:var(--text-3)">
              <span><strong style="color:var(--ok)">Perf <%= p.metrics.perf %>/100</strong></span>
              <span><strong style="color:var(--ok)">SSL <%= p.metrics.sec %></strong></span>
            </div>
            <div class="mockup-actions">
              <a href="https://<%= p.url %>" class="btn btn-primary" target="_blank" rel="noopener">
                Voir le site
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
              <a href="/contact?ref=<%= p.name %>" class="btn btn-ghost">Projet similaire ?</a>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Process</span>
      <h2>Comment on travaille</h2>
      <p>Une méthode éprouvée, transparente, et toujours sécurisée.</p>
    </div>
    <div class="services-grid">
      <div class="card">
        <div class="card-icon" style="background:#eef2ff">
          <strong style="color:var(--brand-1);font-size:1.125rem">01</strong>
        </div>
        <h3>Discovery &amp; cadrage</h3>
        <p>Atelier de cadrage gratuit. On comprend votre besoin, votre cible, vos contraintes. Livrables : brief, planning, devis.</p>
      </div>
      <div class="card">
        <div class="card-icon" style="background:#eef2ff">
          <strong style="color:var(--brand-1);font-size:1.125rem">02</strong>
        </div>
        <h3>Design &amp; maquettes</h3>
        <p>Wireframes puis maquettes haute-fidélité sur Figma. Itérations jusqu'à validation. Vous avez la main.</p>
      </div>
      <div class="card">
        <div class="card-icon" style="background:#eef2ff">
          <strong style="color:var(--brand-1);font-size:1.125rem">03</strong>
        </div>
        <h3>Développement</h3>
        <p>Sprints courts (1-2 sem), démos régulières, code source à vous. Stack moderne, sécurité intégrée.</p>
      </div>
      <div class="card">
        <div class="card-icon" style="background:#eef2ff">
          <strong style="color:var(--brand-1);font-size:1.125rem">04</strong>
        </div>
        <h3>Pen-test &amp; lancement</h3>
        <p>Audit de sécurité avant mise en prod. Mise en ligne progressive. Activation du monitoring SOC.</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="cta-block">
      <h2>Inspiré par ces projets ?</h2>
      <p>On peut faire la même chose pour vous — adapté à votre marché et à votre identité.</p>
      <a href="/contact" class="btn btn-lg">Démarrer mon projet →</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
