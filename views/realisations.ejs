  <!-- ═══════════════════════════════════════════════
       TÉMOIGNAGES CLIENTS
  ═══════════════════════════════════════════════ -->
  <section class="section" style="background:var(--clr-bg-2);border-top:1px solid var(--clr-border);padding:5rem 0;">
    <div class="container">
      <div class="section-header" style="text-align:center;margin-bottom:3.5rem;">
        <p class="section-tag reveal-up">Témoignages</p>
        <h2 class="section-title reveal-up delay-1">Ce que disent <span class="gradient-text">nos clients.</span></h2>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;" class="testimonials-grid">
        <% [
          ['★★★★★', '"Arkis a transformé notre infrastructure digitale. Notre site est passé de 52/100 à 100/100 en une semaine. Aucun incident de sécurité en 18 mois."', 'CEO, DHM-Tech', 'DT'],
          ['★★★★★', '"Leur équipe Red Team a trouvé des vulnérabilités que personne n\'avait jamais repérées. Rapport d\'audit impeccable, corrections faites en 24h."', 'DSI, Fintech Paris', 'FP'],
          ['★★★★★', '"Le simulateur de devis est honnête, le prix était exactement ce que nous avons payé. Zéro surprise, livraison en 3 semaines. Exceptionnel."', 'Fondatrice, L\'Écrin Sucré', 'ES'],
        ].forEach(([stars, quote, name, initials]) => { %>
        <div class="reveal-up" style="background:var(--clr-bg-card);border:1px solid var(--clr-border);border-radius:var(--radius-lg);padding:2rem;display:flex;flex-direction:column;gap:1.25rem;transition:all var(--t-base);">
          <div style="font-size:0.9rem;color:#FBBF24;"><%- stars %></div>
          <p style="font-size:.875rem;color:var(--clr-text-2);line-height:1.7;font-style:italic;flex:1;"><%- quote %></p>
          <div style="display:flex;align-items:center;gap:.75rem;border-top:1px solid var(--clr-border);padding-top:1rem;">
            <div style="width:36px;height:36px;border-radius:50%;background:var(--grad-primary);display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:800;color:#fff;font-family:var(--font-mono);"><%- initials %></div>
            <span style="font-size:.82rem;font-weight:600;color:var(--clr-text);"><%- name %></span>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section" style="padding:5rem 0;border-top:1px solid var(--clr-border);text-align:center;">
    <div class="container" style="max-width:700px;">
      <p class="section-tag reveal-up">Votre tour</p>
      <h2 class="section-title reveal-up delay-1" style="font-size:clamp(1.8rem,4vw,2.8rem);">Votre projet sera<br><span class="gradient-text">notre prochaine référence.</span></h2>
      <p class="section-subtitle reveal-up delay-2" style="margin-inline:auto;">Audit de sécurité gratuit — 30 minutes avec notre équipe. Diagnostic honnête, proposition technique détaillée, zéro engagement.</p>
      <div class="reveal-up delay-3" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2.5rem;">
        <a href="/contact" class="btn btn-primary" id="portfolio-cta-main">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Démarrer mon projet
        </a>
        <a href="/tarifs" class="btn btn-secondary" id="portfolio-cta-tarifs">Voir les tarifs →</a>
      </div>
    </div>
  </section>

</main>

<style>
@media (max-width:900px) {
  .testimonials-grid { grid-template-columns:1fr!important; }
}
@media (max-width:768px) {
  .testimonials-grid { grid-template-columns:1fr!important; }
}
</style>

<%- include('partials/footer') %>
