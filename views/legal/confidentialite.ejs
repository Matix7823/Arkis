<%- include('../partials/head', { 
  title: 'Politique de Confidentialité — Arkis Agency', 
  description: 'Politique de confidentialité exhaustive et traitement rigoureux des données personnelles d\'Arkis Agency en parfaite conformité avec le RGPD.' 
}) %>

<%- include('../partials/header', { page: 'politique-confidentialite' }) %>

<main style="padding-top: var(--nav-h); min-height: 80vh; background-color: var(--clr-bg); color: var(--clr-text);">
  <!-- Background Glow & Grid -->
  <section class="section legal-page" style="background-image: var(--grad-glow); position: relative; padding-bottom: 6rem;">
